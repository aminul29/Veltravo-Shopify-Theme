<style>
  .collections-index {
    padding: 60px 0;
  }

  .collections-index__container {
    width: calc(100% - 30px);
    max-width: 1140px;
    margin: 0 auto;
  }

  .collections-index__header {
    margin-bottom: 36px;
  }

  .collections-index__title {
    margin: 0;
    color: #222222;
    font-size: 34px;
    font-weight: 700;
    line-height: 1.2;
  }

  .collections-index__rule {
    width: 72px;
    height: 3px;
    margin: 14px 0 0;
    background: #26c281;
  }

  .collections-index__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 28px;
  }

  .collections-index__card {
    display: flex;
    flex-direction: column;
    height: 100%;
    border: 1px solid #ececec;
    background: #ffffff;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .collections-index__card:hover {
    transform: translateY(-4px);
    border-color: #dcdcdc;
    box-shadow: 0 18px 38px rgba(17, 24, 39, 0.08);
  }

  .collections-index__media {
    position: relative;
    display: block;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #f7f7f7;
  }

  .collections-index__media img,
  .collections-index__media svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
  }

  .collections-index__card:hover .collections-index__media img,
  .collections-index__card:hover .collections-index__media svg {
    transform: scale(1.03);
  }

  .collections-index__content {
    display: flex;
    flex: 1 1 auto;
    flex-direction: column;
    padding: 20px 20px 22px;
  }

  .collections-index__name {
    margin: 0;
    font-size: 20px;
    font-weight: 700;
    line-height: 1.3;
  }

  .collections-index__name a {
    color: #222222;
  }

  .collections-index__name a:hover {
    color: #26c281;
  }

  .collections-index__meta {
    margin: 10px 0 0;
    color: #777777;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .collections-index__description {
    margin: 14px 0 0;
    color: #666666;
    line-height: 1.75;
  }

  .collections-index__cta {
    margin-top: auto;
    padding-top: 18px;
    color: #26c281;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .collections-index__empty {
    border: 1px dashed #d6d6d6;
    padding: 60px 24px;
    color: #666666;
    text-align: center;
  }

  @media (max-width: 991px) {
    .collections-index__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 575px) {
    .collections-index {
      padding: 40px 0;
    }

    .collections-index__title {
      font-size: 28px;
    }

    .collections-index__grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }
</style>

<section class="collections-index">
  <div class="collections-index__container">
    <header class="collections-index__header">
      <h1 class="collections-index__title">Collections</h1>
      <div class="collections-index__rule"></div>
    </header>

    {% if collections.size > 0 %}
      <div class="collections-index__grid">
        {% for collection in collections %}
          {% assign collection_description = collection.description | strip_html | strip | truncatewords: 18 %}
          <article class="collections-index__card">
            <a class="collections-index__media" href="{{ collection.url }}">
              {% if collection.featured_image != blank %}
                {{ collection.featured_image | image_url: width: 720 | image_tag: loading: 'lazy', alt: collection.title }}
              {% elsif collection.products.first != blank and collection.products.first.featured_image != blank %}
                {{ collection.products.first.featured_image | image_url: width: 720 | image_tag: loading: 'lazy', alt: collection.title }}
              {% else %}
                {{ 'collection-1' | placeholder_svg_tag: 'collections-index__placeholder' }}
              {% endif %}
            </a>

            <div class="collections-index__content">
              <h2 class="collections-index__name"><a href="{{ collection.url }}">{{ collection.title }}</a></h2>
              <p class="collections-index__meta">{{ collection.products_count }} product{% if collection.products_count != 1 %}s{% endif %}</p>

              {% if collection_description != blank %}
                <p class="collections-index__description">{{ collection_description }}</p>
              {% endif %}

              <a class="collections-index__cta" href="{{ collection.url }}">Shop collection</a>
            </div>
          </article>
        {% endfor %}
      </div>
    {% else %}
      <div class="collections-index__empty">
        <p>No collections found.</p>
      </div>
    {% endif %}
  </div>
</section>
