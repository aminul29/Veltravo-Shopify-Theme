<section class="padding-top-60 padding-bottom-60">
  <div class="container">
    <div class="heading"><h2>{{ page.title | default: 'Contact' }}</h2><hr></div>
    {% form 'contact' %}
      {% if form.posted_successfully? %}<p>Thanks for contacting us. We will reply soon.</p>{% endif %}
      {{ form.errors | default_errors }}
      <p><input type="text" name="contact[name]" value="{% if customer %}{{ customer.name }}{% endif %}" placeholder="Name"></p>
      <p><input type="email" name="contact[email]" value="{% if customer %}{{ customer.email }}{% endif %}" placeholder="Email" required></p>
      <p><input type="tel" name="contact[phone]" placeholder="Phone"></p>
      <p><textarea name="contact[body]" rows="6" placeholder="Message" required></textarea></p>
      <button class="btn-round" type="submit">Send</button>
    {% endform %}
  </div>
</section>
