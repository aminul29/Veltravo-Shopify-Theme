<section class="padding-top-60 padding-bottom-60">
  <div class="container">
    <div class="heading"><h2>Your Cart</h2><hr></div>
    {% if cart.item_count > 0 %}
      <form action="{{ routes.cart_url }}" method="post" novalidate>
        <table class="table">
          <thead>
            <tr>
              <th>Product</th>
              <th>Price</th>
              <th>Qty</th>
              <th>Total</th>
            </tr>
          </thead>
          <tbody>
            {% for item in cart.items %}
              <tr>
                <td>
                  <a href="{{ item.url }}">{{ item.product.title }}</a>
                  {% if item.variant.title != 'Default Title' %}<div><small>{{ item.variant.title }}</small></div>{% endif %}
                </td>
                <td>{{ item.final_price | money }}</td>
                <td><input type="number" name="updates[]" value="{{ item.quantity }}" min="0"></td>
                <td>{{ item.final_line_price | money }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
        <p><strong>Subtotal:</strong> {{ cart.total_price | money }}</p>
        <button class="btn-round" type="submit" name="update">Update cart</button>
        <button class="btn-round" type="submit" name="checkout">Checkout</button>
      </form>
    {% else %}
      <p>Your cart is empty.</p>
      <a class="btn-round" href="{{ routes.all_products_collection_url }}">Continue shopping</a>
    {% endif %}
  </div>
</section>
