<section class="padding-top-60 padding-bottom-60"><div class="container"><h1>Reset password</h1>{% form 'reset_customer_password' %}{{ form.errors | default_errors }}<p><input type="password" name="customer[password]" placeholder="New password"></p><p><input type="password" name="customer[password_confirmation]" placeholder="Confirm password"></p><button class="btn-round" type="submit">Reset password</button>{% endform %}</div></section>
