<section class="padding-top-60 padding-bottom-60">
  <div class="container">
    <h1>Login</h1>
    {% form 'customer_login' %}
      {{ form.errors | default_errors }}
      <p><input type="email" name="customer[email]" placeholder="Email" autocomplete="email"></p>
      <p><input type="password" name="customer[password]" placeholder="Password" autocomplete="current-password"></p>
      <button class="btn-round" type="submit">Sign in</button>
    {% endform %}
    <p><a href="{{ routes.account_register_url }}">Create account</a></p>
    <p><a href="#recover">Forgot password?</a></p>

    <div id="recover">
      <h3>Reset password</h3>
      {% form 'recover_customer_password' %}
        {{ form.errors | default_errors }}
        {% if form.posted_successfully? %}<p>Check your email for reset instructions.</p>{% endif %}
        <p><input type="email" name="email" placeholder="Email"></p>
        <button class="btn-round" type="submit">Send reset link</button>
      {% endform %}
    </div>
  </div>
</section>
