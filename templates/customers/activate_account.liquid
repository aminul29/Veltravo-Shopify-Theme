<section class="padding-top-60 padding-bottom-60"><div class="container"><h1>Activate account</h1>{% form 'activate_customer_password' %}{{ form.errors | default_errors }}<p><input type="password" name="customer[password]" placeholder="Password"></p><p><input type="password" name="customer[password_confirmation]" placeholder="Confirm password"></p><button class="btn-round" type="submit">Activate</button><button class="btn-round" name="decline" type="submit">Decline invitation</button>{% endform %}</div></section>
