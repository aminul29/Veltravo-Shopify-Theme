<section class="padding-top-60 padding-bottom-60"><div class="container"><h1>Create account</h1>{% form 'create_customer' %}{{ form.errors | default_errors }}<p><input type="text" name="customer[first_name]" placeholder="First name"></p><p><input type="text" name="customer[last_name]" placeholder="Last name"></p><p><input type="email" name="customer[email]" placeholder="Email"></p><p><input type="password" name="customer[password]" placeholder="Password"></p><button class="btn-round" type="submit">Create</button>{% endform %}</div></section>
