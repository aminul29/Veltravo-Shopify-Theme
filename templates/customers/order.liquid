<section class="padding-top-60 padding-bottom-60">
  <div class="container">
    <h1>Order {{ order.name }}</h1>
    <p><a href="{{ routes.account_url }}">Back to account</a></p>
    <table class="table">
      <thead><tr><th>Product</th><th>SKU</th><th>Price</th><th>Qty</th><th>Total</th></tr></thead>
      <tbody>
        {% for line_item in order.line_items %}
          <tr>
            <td>{{ line_item.title }}</td>
            <td>{{ line_item.sku }}</td>
            <td>{{ line_item.price | money }}</td>
            <td>{{ line_item.quantity }}</td>
            <td>{{ line_item.final_line_price | money }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
    <p><strong>Total:</strong> {{ order.total_price | money_with_currency }}</p>
  </div>
</section>
