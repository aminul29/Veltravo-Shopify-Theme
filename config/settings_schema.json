        "default": "#f6f7fb"
      },
      {
        "type": "color",
        "id": "color_surface",
        "label": "t:settings_schema.colors.settings.surface.label",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "t:settings_schema.colors.settings.text.label",
        "default": "#111827"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "t:settings_schema.colors.settings.accent.label",
        "default": "#1f6df0"
      }
    ]
  },
  {
    "name": "t:settings_schema.typography.name",
    "settings": [
      {
        "type": "header",
        "content": "t:settings_schema.typography.settings.heading.content"
      },
      {
        "type": "range",
        "id": "type_scale",
        "label": "t:settings_schema.typography.settings.type_scale.label",
        "min": 90,
        "max": 120,
        "step": 2,
        "unit": "%",
        "default": 100
      }
    ]
  },
  {
    "name": "t:settings_schema.layout.name",
    "settings": [
      {
        "type": "header",
        "content": "t:settings_schema.layout.settings.heading.content"
      },
      {
        "type": "range",
        "id": "container_width",
