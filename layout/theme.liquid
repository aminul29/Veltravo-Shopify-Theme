<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="content-type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="author" content="M_Adnan">
    <meta name="theme-color" content="{{ settings.color_accent }}">
    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}
    <title>
      {{ page_title }}
      {%- if current_tags -%}
        {{ ' | ' }}{{ current_tags | join: ', ' }}
      {%- endif -%}
      {%- if current_page != 1 -%}
        {{ ' | ' }}{{ 'general.meta.page' | t: page: current_page }}
      {%- endif -%}
      {%- unless page_title contains shop.name -%}
        {{ ' | ' }}{{ shop.name }}
      {%- endunless -%}
    </title>
    {{ content_for_header }}
    <link href="https://fonts.googleapis.com/css?family=Lato:100i,300,400,700,900" rel="stylesheet">
    {{ 'template-rs-settings.css' | asset_url | stylesheet_tag }}
    {{ 'template-ionicons.css' | asset_url | stylesheet_tag }}
    {{ 'template-bootstrap.css' | asset_url | stylesheet_tag }}
    {{ 'template-font-awesome.css' | asset_url | stylesheet_tag }}
    {{ 'template-main.css' | asset_url | stylesheet_tag }}
    {{ 'template-style.css' | asset_url | stylesheet_tag }}
    {{ 'template-responsive.css' | asset_url | stylesheet_tag }}
    {% liquid
      assign starter_templates = '404,article,blog,cart,collection,page,product,search,customers/account,customers/addresses,customers/login,customers/order,customers/register,customers/reset_password' | split: ','
      assign uses_starter_assets = false
      if starter_templates contains template
        assign uses_starter_assets = true
      endif
    %}
    {% if uses_starter_assets %}
      {{ 'application.css' | asset_url | stylesheet_tag }}
      <script defer src="{{ 'alpine.min.js' | asset_url }}"></script>
      <style>
        [x-cloak] { display: none !important; }
      </style>
    {% endif %}
    {{ 'template-modernizr.js' | asset_url | script_tag }}
    <!--[if lt IE 9]>
      <script src="https://oss.maxcdn.com/html5shiv/3.7.2/html5shiv.min.js"></script>
      <script src="https://oss.maxcdn.com/respond/1.4.2/respond.min.js"></script>
    <![endif]-->
    {% style %}
      :root {
        --container-width: {{ settings.container_width | default: 1280 }}px;
        --color-background: {{ settings.color_background | default: '#f6f7fb' }};
        --color-surface: {{ settings.color_surface | default: '#ffffff' }};
        --color-text: {{ settings.color_text | default: '#111827' }};
        --color-accent: {{ settings.color_accent | default: '#1f6df0' }};
        --type-scale: {{ settings.type_scale | default: 100 | divided_by: 100.0 }};
      }
    {% endstyle %}
  </head>
  <body>
    <div id="wrap" class="layout-9">
      {% sections 'header-group' %}
      {{ content_for_layout }}
      {% sections 'footer-group' %}
    </div>
    {{ 'template-jquery.min.js' | asset_url | script_tag }}
    {{ 'template-wow.min.js' | asset_url | script_tag }}
    {{ 'template-bootstrap.min.js' | asset_url | script_tag }}
    {{ 'template-own-menu.js' | asset_url | script_tag }}
    {{ 'template-jquery.sticky.js' | asset_url | script_tag }}
    {{ 'template-owl.carousel.min.js' | asset_url | script_tag }}
    {{ 'template-jquery.tp.t.min.js' | asset_url | script_tag }}
    {{ 'template-jquery.tp.min.js' | asset_url | script_tag }}
    {{ 'template-main.js' | asset_url | script_tag }}
    {% if uses_starter_assets %}
      <script src="{{ 'application.js' | asset_url }}" defer></script>
    {% endif %}
  </body>
</html>
