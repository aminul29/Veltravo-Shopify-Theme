<style>
  .cart-template {
    padding: 48px 0 64px;
  }

  .cart-template__container {
    width: calc(100% - 30px);
    max-width: 1140px;
    margin: 0 auto;
  }

  .cart-template__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 28px;
  }

  .cart-template__title {
    margin: 0;
    color: #1f2937;
    font-size: 34px;
    font-weight: 700;
    line-height: 1.15;
  }

  .cart-template__continue {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 22px;
    border: 1px solid #d8dde3;
    border-radius: 999px;
    color: #1f2937;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .cart-template__continue:hover {
    border-color: #26c281;
    color: #26c281;
  }

  .cart-template__shell {
    border: 1px solid #e8ebef;
    border-radius: 22px;
    background: #ffffff;
    box-shadow: 0 14px 34px rgba(15, 23, 42, 0.05);
    overflow: hidden;
  }

  .cart-template__row {
    display: grid;
    grid-template-columns: minmax(0, 1.7fr) 150px 140px;
    gap: 24px;
    align-items: center;
    padding: 28px 32px;
    border-bottom: 1px solid #eef1f4;
  }

  .cart-template__item {
    display: flex;
    align-items: center;
    gap: 20px;
    min-width: 0;
  }

  .cart-template__media {
    flex: 0 0 116px;
    width: 116px;
    height: 116px;
    border-radius: 18px;
    overflow: hidden;
    background: #f5f7fa;
  }

  .cart-template__media img,
  .cart-template__media svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-template__vendor {
    display: inline-block;
    margin-bottom: 8px;
    color: #8a94a6;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .cart-template__product-title {
    margin: 0;
    color: #1f2937;
    font-size: 22px;
    line-height: 1.38;
    font-weight: 700;
  }

  .cart-template__product-title a {
    color: inherit;
  }

  .cart-template__product-title a:hover {
    color: #26c281;
  }

  .cart-template__variant {
    margin-top: 8px;
    color: #6b7280;
  }

  .cart-template__remove {
    display: inline-block;
    margin-top: 12px;
    color: #dc2626;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .cart-template__remove:hover {
    color: #b91c1c;
  }

  .cart-template__label {
    display: block;
    margin-bottom: 8px;
    color: #8a94a6;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .cart-template__quantity-input {
    width: 100%;
    height: 46px;
    border: 1px solid #d7dde5;
    border-radius: 999px;
    padding: 0 14px;
    text-align: center;
    color: #1f2937;
    background: #ffffff;
  }

  .cart-template__line-total {
    text-align: right;
  }

  .cart-template__line-price {
    margin: 0;
    color: #1f2937;
    font-size: 26px;
    font-weight: 700;
  }

  .cart-template__footer {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(320px, 460px);
    gap: 28px;
    padding: 32px;
    background: #f8fafc;
  }

  .cart-template__notes-label {
    display: block;
    margin-bottom: 10px;
    color: #1f2937;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .cart-template__notes {
    width: 100%;
    min-height: 152px;
    border: 1px solid #d7dde5;
    border-radius: 18px;
    padding: 16px 18px;
    resize: vertical;
    background: #ffffff;
    color: #374151;
  }

  .cart-template__summary {
    padding: 26px 28px 28px;
    border: 1px solid #e8ebef;
    border-radius: 22px;
    background: #ffffff;
  }

  .cart-template__summary-title {
    margin: 0 0 18px;
    color: #1f2937;
    font-size: 22px;
    font-weight: 700;
  }

  .cart-template__subtotal {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 0 22px;
    border-top: 1px solid #eef1f4;
    border-bottom: 1px solid #eef1f4;
  }

  .cart-template__subtotal-label {
    color: #374151;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .cart-template__subtotal-value {
    color: #1f2937;
    font-size: 32px;
    font-weight: 700;
  }

  .cart-template__summary-copy {
    margin: 16px 0 0;
    color: #6b7280;
    line-height: 1.8;
  }

  .cart-template__actions {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-top: 24px;
  }

  .cart-template__button {
    width: 100%;
    min-height: 48px;
    border: none;
    border-radius: 999px;
    padding: 0 22px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .cart-template__button:hover {
    transform: translateY(-1px);
  }

  .cart-template__button--secondary {
    background: #e5e7eb;
    color: #1f2937;
  }

  .cart-template__button--secondary:hover {
    background: #d9dce1;
  }

  .cart-template__button--primary {
    background: #26c281;
    color: #ffffff;
    box-shadow: 0 12px 26px rgba(38, 194, 129, 0.22);
  }

  .cart-template__button--primary:hover {
    background: #20b172;
  }

  .cart-template__empty {
    padding: 72px 24px;
    border: 1px dashed #d5dbe3;
    border-radius: 22px;
    text-align: center;
  }

  .cart-template__empty-title {
    margin: 0;
    color: #1f2937;
    font-size: 28px;
    font-weight: 700;
  }

  .cart-template__empty-copy {
    max-width: 520px;
    margin: 14px auto 0;
    color: #6b7280;
    line-height: 1.8;
  }

  .cart-template__empty-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    margin-top: 24px;
    padding: 0 24px;
    border-radius: 999px;
    background: #26c281;
    color: #ffffff;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .cart-template__empty-action:hover {
    background: #20b172;
    color: #ffffff;
  }

  @media (max-width: 991px) {
    .cart-template__row {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .cart-template__line-total {
      text-align: left;
    }

    .cart-template__footer {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 575px) {
    .cart-template {
      padding: 36px 0 48px;
    }

    .cart-template__header {
      flex-direction: column;
      align-items: flex-start;
    }

    .cart-template__title {
      font-size: 30px;
    }

    .cart-template__row,
    .cart-template__footer {
      padding: 22px;
    }

    .cart-template__item {
      align-items: flex-start;
    }

    .cart-template__media {
      flex-basis: 92px;
      width: 92px;
      height: 92px;
    }

    .cart-template__product-title {
      font-size: 19px;
    }

    .cart-template__subtotal-value {
      font-size: 28px;
    }
  }
</style>

<section class="cart-template">
  <div class="cart-template__container">
    {% if cart.item_count > 0 %}
      <div class="cart-template__header">
        <h1 class="cart-template__title">Your Cart</h1>
        <a href="{{ routes.all_products_collection_url }}" class="cart-template__continue">Continue Shopping</a>
      </div>

      <div class="cart-template__shell">
        <form action="{{ routes.cart_url }}" method="post" novalidate>
          {% for item in cart.items %}
            <div class="cart-template__row">
              <div class="cart-template__item">
                <a class="cart-template__media" href="{{ item.url }}">
                  {% if item.image %}
                    {{ item.image | image_url: width: 240 | image_tag: loading: 'lazy', alt: item.product.title }}
                  {% else %}
                    {{ 'product-1' | placeholder_svg_tag: 'cart-template__placeholder' }}
                  {% endif %}
                </a>

                <div>
                  {% if item.vendor != blank %}
                    <span class="cart-template__vendor">{{ item.vendor }}</span>
                  {% endif %}

                  <h2 class="cart-template__product-title">
                    <a href="{{ item.url }}">{{ item.product.title }}</a>
                  </h2>

                  {% unless item.variant.title == 'Default Title' %}
                    <p class="cart-template__variant">{{ item.variant.title }}</p>
                  {% endunless %}

                  <a class="cart-template__remove" href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity=0">Remove</a>
                </div>
              </div>

              <div>
                <label class="cart-template__label" for="updates_{{ forloop.index }}">Quantity</label>
                <input
                  class="cart-template__quantity-input"
                  type="number"
                  name="updates[]"
                  id="updates_{{ forloop.index }}"
                  value="{{ item.quantity }}"
                  min="1"
                >
              </div>

              <div class="cart-template__line-total">
                <span class="cart-template__label">Total</span>
                <p class="cart-template__line-price">{{ item.line_price | money }}</p>
              </div>
            </div>
          {% endfor %}

          <div class="cart-template__footer">
            <div>
              <label class="cart-template__notes-label" for="cart_notes">Cart Notes</label>
              <textarea class="cart-template__notes" name="note" id="cart_notes" rows="5" placeholder="Add any special instructions here">{{ cart.note }}</textarea>
            </div>

            <div class="cart-template__summary">
              <h3 class="cart-template__summary-title">Order Summary</h3>

              {% for block in section.blocks %}
                {% case block.type %}
                  {% when 'subtotal' %}
                    <div class="cart-template__subtotal" {{ block.shopify_attributes }}>
                      <span class="cart-template__subtotal-label">Subtotal</span>
                      <span class="cart-template__subtotal-value">{{ cart.total_price | money }}</span>
                    </div>
                  {% when 'update_button' %}
                  {% when 'checkout_button' %}
                {% endcase %}
              {% endfor %}

              <p class="cart-template__summary-copy">Shipping, taxes, and discounts are calculated during checkout.</p>

              <div class="cart-template__actions">
                {% for block in section.blocks %}
                  {% case block.type %}
                    {% when 'update_button' %}
                      <button
                        type="submit"
                        name="update"
                        class="cart-template__button cart-template__button--secondary"
                        {{ block.shopify_attributes }}
                      >
                        {{ section.settings.update_button_text | default: 'Update Cart' }}
                      </button>
                    {% when 'checkout_button' %}
                      <button
                        type="submit"
                        name="checkout"
                        class="cart-template__button cart-template__button--primary"
                        {{ block.shopify_attributes }}
                      >
                        {{ section.settings.checkout_button_text | default: 'Checkout' }}
                      </button>
                  {% endcase %}
                {% endfor %}
              </div>
            </div>
          </div>
        </form>
      </div>
    {% else %}
      <div class="cart-template__empty">
        <h1 class="cart-template__empty-title">Your cart is empty</h1>
        <p class="cart-template__empty-copy">Add a few items you love and come back here when you're ready to check out.</p>
        <a href="{{ routes.all_products_collection_url }}" class="cart-template__empty-action">Go to Products</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Template Cart",
  "settings": [
    {
      "type": "text",
      "id": "update_button_text",
      "label": "Update Button Text",
      "default": "Update Cart"
    },
    {
      "type": "text",
      "id": "checkout_button_text",
      "label": "Checkout Button Text",
      "default": "Checkout"
    }
  ],
  "blocks": [
    {
      "type": "subtotal",
      "name": "Subtotal",
      "limit": 1
    },
    {
      "type": "update_button",
      "name": "Update Button",
      "limit": 1
    },
    {
      "type": "checkout_button",
      "name": "Checkout Button",
      "limit": 1
    }
  ],
  "presets": [
    {
      "name": "Cart Page",
      "blocks": [
        {
          "type": "subtotal"
        },
        {
          "type": "update_button"
        },
        {
          "type": "checkout_button"
        }
      ]
    }
  ]
}
{% endschema %}
