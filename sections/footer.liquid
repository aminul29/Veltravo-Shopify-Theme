{%- liquid
  assign top_links_menu = section.settings.top_links_menu
  assign categories_menu = section.settings.categories_menu
  assign services_menu = section.settings.services_menu
  assign information_menu = section.settings.information_menu
  assign contact_phone = section.settings.contact_phone
  assign contact_email = section.settings.contact_email
  assign contact_text = section.settings.contact_text
  assign footer_text = section.settings.footer_text
  -%}

<footer>
  <div class="container">
    <div class="foot-link">
      <ul>
        {% if top_links_menu != blank and top_links_menu.links.size > 0 %}
          {% for link in top_links_menu.links %}
            <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
          {% endfor %}
        {% endif %}
      </ul>
    </div>

    <div class="row">
      <div class="col-md-4">
        <h4>About Veltravo!</h4>
          <p>Veltravo brings you innovative gadgets and smart home solutions designed to make everyday life easier.
We deliver premium products with secure payments and worldwide shipping.</p>
<p>
<strong>Email:</strong> {{ contact_email }}
</p>
        <div class="social-links">
          <a href="{{ settings.social_facebook | default: '#' }}" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
          <a href="{{ settings.social_x | default: '#' }}" aria-label="X"><i class="fab fa-twitter"></i></a>
          <a href="{{ settings.social_pinterest | default: '#' }}" aria-label="Pinterest"><i class="fab fa-pinterest"></i></a>
          <a href="{{ settings.social_instagram | default: '#' }}" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
          <a href="{{ settings.social_google | default: '#' }}" aria-label="Google"><i class="fab fa-google"></i></a>
        </div>
      </div>

      <div class="col-md-3">
        <h4>Quick Links</h4>
        <ul class="links-footer">
          {% if categories_menu != blank and categories_menu.links.size > 0 %}
            {% for link in categories_menu.links %}
              <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
            {% endfor %}
          {% endif %}
        </ul>
      </div>

      <div class="col-md-3">
        <h4>Customer Care</h4>
        <ul class="links-footer">
          {% if services_menu != blank and services_menu.links.size > 0 %}
            {% for link in services_menu.links %}
              <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
            {% endfor %}
          {% else %}
            <li><a href="{{ routes.search_url }}">Search</a></li>
            <li><a href="{{ routes.cart_url }}">Cart</a></li>
            {% if shop.customer_accounts_enabled %}
              {% if customer %}
                <li><a href="{{ routes.account_url }}">My Account</a></li>
                <li>{{ 'Log out' | customer_logout_link }}</li>
              {% else %}
                <li><a href="{{ routes.account_login_url }}">Login</a></li>
                <li><a href="{{ routes.account_register_url }}">Register</a></li>
              {% endif %}
            {% endif %}
          {% endif %}
        </ul>
      </div>

      <div class="col-md-2">
        <h4>Explore</h4>
        <ul class="links-footer">
          {% if information_menu != blank and information_menu.links.size > 0 %}
            {% for link in information_menu.links %}
              <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
            {% endfor %}
          {% else %}
            <li><a href="{{ routes.all_products_collection_url }}">Shop</a></li>
            <li><a href="{{ routes.collections_url }}">Collections</a></li>
            <li><a href="/pages/contact">Contact</a></li>
            {% if shop.privacy_policy != blank %}
              <li><a href="{{ shop.privacy_policy.url }}">Privacy policy</a></li>
            {% endif %}
            {% if shop.refund_policy != blank %}
              <li><a href="{{ shop.refund_policy.url }}">Refund policy</a></li>
            {% endif %}
            {% if shop.shipping_policy != blank %}
              <li><a href="{{ shop.shipping_policy.url }}">Shipping policy</a></li>
            {% endif %}
            {% if shop.terms_of_service != blank %}
              <li><a href="{{ shop.terms_of_service.url }}">Terms of service</a></li>
            {% endif %}
          {% endif %}
        </ul>
      </div>
    </div>
  </div>
</footer>
<div class="trust-bar">
    🚚 Worldwide Shipping
    🔒 Secure Checkout
    💬 24/7 Support
</div>
<div class="rights">
  <div class="container">
    <div class="row">
      <div class="col-sm-6">
        {% if footer_text != blank %}
          <p>{{ footer_text }}</p>
        {% else %}
          <p>© 2026 Veltravo. All Rights Reserved.</p>
        {% endif %}
      </div>
      <div class="col-sm-6 text-right">
        <div class="rights__payments">
    <img src="https://cdn.shopify.com/s/files/1/0991/0049/2066/files/2018-PaynowTopup-badge-RGB_1.png?v=1782170901"
         alt="Secure Payment Methods"
         style="max-height:60px;width:auto;">
</div>
      </div>
    </div>
  </div>
</div>

<a href="#" class="cd-top" aria-label="Back to top"><i class="fa fa-angle-up"></i></a>

{% stylesheet %}
 footer,
.rights {
    background: #0f172a !important;
}

  #shopify-section-{{ section.id }} .container {
    width: calc(100% - 30px) !important;
    max-width: 1140px !important;
    margin: 0 auto !important;
  }

  footer h4{
font-size:20px;
color:#fff;
font-weight:700;
}

  footer p {
   color:#B8C2D1;
    margin-top: 0;
  }

  .foot-link {
    border-bottom: 1px solid #111827;
    margin-bottom: 60px;
  }

  .foot-link ul {
    margin: 0;
     padding: 60px 0 20px;
    list-style: none;
  }

  .foot-link li {
    display: inline-block;
    margin-right: 20px;
  }

  .foot-link li a {
    font-size: 14px;
    display: inline-block;
    padding: 15px 0;
    color:white;
  }

  .row {
    display: flex;
    flex-wrap: wrap;
    margin-left: -15px;
    margin-right: -15px;
    row-gap:25px;
  }

  [class*="col-md-"],
  [class*="col-sm-"] {
    position: relative;
    min-height: 1px;
    padding-left: 15px;
    padding-right: 15px;
  }

  footer .row{
    display:flex;
    justify-content:space-between;
    gap:40px;
    flex-wrap:wrap;
}

footer .row > div{
    flex:1;
    min-width:220px;
}

  .text-right {
    text-align: right;
  }

  .social-links {
    margin-top: 30px;
  }

  .social-links a{
color:white;
font-size:22px;
}

  .links-footer {
    margin: 0;
    padding: 0;
  }

  .links-footer li {
    list-style: none;
  }

  .links-footer a{
color:#D6DCE7;
transition:.3s;
}

.links-footer a:hover{
color:#2ECC71;
padding-left:6px;
}

  .contact-copy > *:first-child {
    margin-top: 0;
  }

  .rights{
background:#111827;
padding:20px 0;
display:flex;
align-items:center;
justify-content:space-between;
}

  .rights p {
    margin-bottom: 0;
    font-size: 14px;
    margin-top: 8px;
  }

  .rights ul {
    text-align: right;
    margin-bottom: 0;
    padding: 0;
    list-style: none;
  }

  .rights__payments {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
    gap: 0.4rem;
  }

  .rights__payments svg {
    width: 42px;
    height: auto;
  }
.payment-badges{
display:flex;
justify-content:flex-end;
align-items:center;
}
.trust-bar{
    display:flex;
    justify-content:center;
    gap:60px;
   background:#111827;
border-top:1px solid rgba(255,255,255,.08);
border-bottom:1px solid rgba(255,255,255,.08);
padding:25px 0;
}
  .rights .text-right img {
    display: inline-block;
    max-width: 100%;
  }

  .ri-li {
    color: #555555;
  }

  .cd-top {
    display: inline-block;
    height: 40px;
    width: 40px;
    z-index: 9;
    position: fixed;
    bottom: 10px;
    right: 10px;
    color: #000000;
    border-radius: 50%;
    font-size: 26px;
    text-align: center;
    line-height: 32px;
    border: 2px solid #000000;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.05);
    overflow: hidden;
    white-space: nowrap;
    background: none;
    visibility: hidden;
    opacity: 0;
    transition: all 0.4s ease-in-out;
  }

  .cd-top.cd-is-visible,
  .cd-top.cd-fade-out,
  .no-touch .cd-top:hover {
    transition: opacity 0.3s 0s, visibility 0s 0s;
  }

  .cd-top.cd-is-visible {
    visibility: visible;
    opacity: 0.5;
  }

  .cd-top.cd-fade-out {
    opacity: 0.5;
  }

  .no-touch .cd-top:hover {
    background-color: #000000;
    color: #111827;
  }

  .row{
    display:flex;
    justify-content:space-between;
    flex-wrap:nowrap;
    gap:40px;
}

.col-md-4,
.col-md-3,
.col-md-2{
    width:auto;
    flex:1;
}

.col-md-4{
    flex:1.3;
}

    footer h4 {
      display: inline-block;
      width: 100%;
    }
  }

  @media screen and (max-width: 767px) {
    .foot-link {
      margin-bottom: 30px;
    }

    .foot-link li {
      margin-right: 12px;
    }

    .row {
      margin-left: -10px;
      margin-right: -10px;
    }

    .col-md-4,
    .col-md-3,
    .col-md-2,
     .col-sm-6 {
      width: 100%;
      float: none;
    }

    footer h4 {
      margin-top: 20px;
      margin-bottom: 0;
    }

    .rights {
      text-align: center;
    }

    .rights .text-right {
      margin-top: 20px;
      text-align: center !important;
    }

    .rights .row {
      flex-direction: column;
    }

    .rights ul {
      text-align: center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.footer.name",
  "class": "section-footer",
  "settings": [
    {
      "type": "link_list",
      "id": "top_links_menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "categories_menu",
      "label": "t:labels.category_menu"
    },
    {
      "type": "link_list",
      "id": "services_menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "information_menu",
      "label": "t:labels.menu"
    },
    {
      "type": "richtext",
      "id": "contact_text",
      "label": "t:labels.contact_text",
      "default": "<p>Address: 45 Grand Central Terminal New York, NY 1017 United State USA</p>"
    },
    {
      "type": "text",
      "id": "contact_phone",
      "label": "Phone",
      "default": "(+100) 123 456 7890"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Email",
      "default": "Support@smarttech.com"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "t:labels.footer_text",
      "default": "Copyright &copy; 2017 SmartTech HTML5 template. All rights reserved"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:labels.show_payment_icons",
      "default": true
    }
  ]
}
{% endschema %}
