    {
      "type": "text",
      "id": "form_heading",
      "label": "Form heading",
      "default": "Do You have a Question for Us ?"
    },
    {
      "type": "text",
      "id": "name_label",
      "label": "Full name label",
      "default": "Full Name"
    },
    {
      "type": "text",
      "id": "first_name_label",
      "label": "First name label",
      "default": "First Name"
    },
    {
      "type": "text",
      "id": "last_name_label",
      "label": "Last name label",
      "default": "Last Name"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email label",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "phone_label",
      "label": "Phone label",
      "default": "Phone"
    },
    {
      "type": "text",
      "id": "message_label",
      "label": "Message label",
      "default": "Message"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Send Message"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thanks for contacting us. We will reply soon."
    },
    {
      "type": "text",
      "id": "map_label",
      "label": "Map label",
      "default": "Store map"
    },
    {
      "type": "url",
      "id": "map_embed_url",
      "label": "Map embed URL"
    },
    {
      "type": "text",
      "id": "info_title",
      "label": "Info title",
      "default": "SmartTech"
    },
    {
      "type": "textarea",
      "id": "info_text",
      "label": "Info text",
      "default": "The most powerful PSD for Digital & Electronic!"
    },
    {
      "type": "text",
      "id": "address_heading",
      "label": "Address heading",
      "default": "Address:"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Address",
      "default": "45 Grand Central Terminal New York, NY 1017\nUnited State USA"
    },
    {
      "type": "text",
      "id": "phone_heading",
      "label": "Phone heading",
      "default": "Phone:"
    },
    {
      "type": "text",
      "id": "phone_primary",
      "label": "Primary phone",
      "default": "(+100) 123 456 7890"
    },
    {
      "type": "text",
      "id": "phone_secondary",
      "label": "Secondary phone",
      "default": "(+100) 987 654 3210"
    },
    {
      "type": "text",
      "id": "email_heading",
      "label": "Email heading",
      "default": "Email:"
    },
    {
      "type": "text",
      "id": "email_primary",
      "label": "Primary email",
      "default": "Support@smarttech.com"
    },
    {
      "type": "text",
      "id": "email_secondary",
      "label": "Secondary email",
      "default": "Support24/7@smarttech.com"
    }
  ],
  "presets": [
    {
      "name": "Contact Form"
    }
  ]
}
{% endschema %}
