<section class="categories-grid section-shell">
  <div class="page-width">
    <div class="section-heading">
      <h2>
        {% if section.settings.heading != blank %}
          {{ section.settings.heading | escape }}
        {% else %}
          {{ 'sections.featured_categories_grid.default_heading' | t }}
        {% endif %}
      </h2>
      {% if section.settings.subheading != blank %}
        <p>{{ section.settings.subheading | escape }}</p>
      {% endif %}
    </div>
    <div class="categories-grid__grid">
      {% for block in section.blocks %}
        {%- liquid
          assign card_title = block.settings.title_override
          assign card_url = block.settings.link
          assign card_image = block.settings.image_override
          if block.settings.collection != blank
            assign card_url = block.settings.collection.url
            if card_title == blank
              assign card_title = block.settings.collection.title
            endif
            if card_image == blank
              assign card_image = block.settings.collection.featured_image
            endif
            if card_image == blank and block.settings.collection.products_count > 0
              assign card_image = block.settings.collection.products.first.featured_image
            endif
          endif
        -%}
        <article class="categories-grid__card card-surface" {{ block.shopify_attributes }}>
          <a href="{{ card_url | default: routes.all_products_collection_url }}">
            <div class="categories-grid__media">
              {% if card_image != blank %}
                {{ card_image | image_url: width: 720 | image_tag: loading: 'lazy', widths: '280, 480, 720', alt: card_title | escape }}
              {% else %}
                {{ 'collection-1' | placeholder_svg_tag: 'categories-grid__placeholder' }}
              {% endif %}
            </div>
            <div class="categories-grid__copy">
              <h3>{{ card_title | default: shop.name | escape }}</h3>
              {% if block.settings.description != blank %}
                <p>{{ block.settings.description | escape }}</p>
              {% endif %}
            </div>
          </a>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .categories-grid__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .categories-grid__card {
    overflow: hidden;
  }

  .categories-grid__media {
    aspect-ratio: 5 / 4;
    background: linear-gradient(135deg, rgba(31, 109, 240, 0.08), rgba(17, 24, 39, 0.04));
  }

  .categories-grid__media img,
  .categories-grid__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .categories-grid__placeholder {
    padding: 2rem;
  }

  .categories-grid__copy {
    padding: 1.1rem;
  }

  .categories-grid__copy h3,
  .categories-grid__copy p {
    margin: 0;
  }

  .categories-grid__copy p {
    margin-top: 0.45rem;
    color: color-mix(in srgb, var(--color-text) 70%, transparent);
  }

  @media screen and (max-width: 989px) {
    .categories-grid__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .categories-grid__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.featured_categories_grid.name",
  "class": "section-featured-categories-grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:labels.subheading"
    }
  ],
  "blocks": [
    {
      "type": "category_card",
      "name": "t:sections.featured_categories_grid.name",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:labels.collection"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:labels.link"
        },
        {
          "type": "image_picker",
          "id": "image_override",
          "label": "t:labels.image_override"
        },
        {
          "type": "text",
          "id": "title_override",
          "label": "t:labels.title_override"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:labels.description"
        }
      ]
    }
  ],
  "max_blocks": 9,
  "presets": [
    {
      "name": "t:sections.featured_categories_grid.name",
      "blocks": [
        {
          "type": "category_card"
        },
        {
          "type": "category_card"
        },
        {
          "type": "category_card"
        },
        {
          "type": "category_card"
        },
        {
          "type": "category_card"
        },
        {
          "type": "category_card"
        }
      ]
    }
  ]
}
{% endschema %}
