<section class="store-benefits section-shell">
  <div class="page-width">
    <div class="section-heading">
      <h2>
        {% if section.settings.heading != blank %}
          {{ section.settings.heading | escape }}
        {% else %}
          {{ 'sections.store_benefits.default_heading' | t }}
        {% endif %}
      </h2>
    </div>
    <div class="store-benefits__grid">
      {% for block in section.blocks %}
        <article class="store-benefits__card card-surface" {{ block.shopify_attributes }}>
          <span class="pill">{{ block.settings.icon_label | default: forloop.index }}</span>
          <div>
            <h3>{{ block.settings.title | escape }}</h3>
            {% if block.settings.text != blank %}
              <p>{{ block.settings.text | escape }}</p>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .store-benefits__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .store-benefits__card {
    display: grid;
    gap: 1rem;
    align-content: start;
    padding: 1.25rem;
  }

  .store-benefits__card h3,
  .store-benefits__card p {
    margin: 0;
  }

  .store-benefits__card p {
    margin-top: 0.45rem;
    color: color-mix(in srgb, var(--color-text) 72%, transparent);
  }

  @media screen and (max-width: 989px) {
    .store-benefits__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .store-benefits__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.store_benefits.name",
  "class": "section-store-benefits",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "t:sections.store_benefits.name",
      "settings": [
        {
          "type": "text",
          "id": "icon_label",
          "label": "t:labels.icon_label",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.title",
          "default": "Fast fulfillment"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "t:labels.text",
          "default": "Use short proof points for shipping, returns, support, or secure checkout."
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "t:sections.store_benefits.name",
      "blocks": [
        {
          "type": "benefit"
        },
        {
          "type": "benefit",
          "settings": {
            "icon_label": "02",
            "title": "Easy returns"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon_label": "03",
            "title": "Support all week"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon_label": "04",
            "title": "Trusted payments"
          }
        }
      ]
    }
  ]
}
{% endschema %}
