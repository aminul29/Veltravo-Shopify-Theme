<!-- Banner -->
<section class="disply-sec promo-tile-row-section margin-bottom-0">
  <div class="container">
    <div class="row">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          {% render 'promo-tile-item', block: block %}
        {% endfor %}
      {% else %}
        {% render 'promo-tile-item', fallback_variant: 'regular', fallback_subtitle: 'New line required', fallback_title: 'Z68 Web Camera', fallback_price: '$85.00', fallback_link: '#.' %}
        {% render 'promo-tile-item', fallback_variant: 'watch', fallback_subtitle: 'No restocking fee ($35 savings)', fallback_title: 'SmartPhone', fallback_price: '$450.00', fallback_link: '#.' %}
        {% render 'promo-tile-item', fallback_variant: 'sale', fallback_title: 'Huge', fallback_highlight: 'Sale!', fallback_text: 'Saving up to 50% off all online store items this week.', fallback_button_label: 'Shop now', fallback_link: '#.' %}
      {% endif %}
    </div>
  </div>
</section>

{% style %}
  #shopify-section-{{ section.id }} .promo-tile-row-section {
    position: relative;
    clear: both;
    margin-top: 0;
    margin-bottom: 0;
  }

  #shopify-section-{{ section.id }} .promo-tile-row-section .container {
    padding-top: 0;
  }

  #shopify-section-{{ section.id }} .promo-tile-row-section .product {
    margin-bottom: 0;
  }

  #shopify-section-{{ section.id }} .promo-tile-row-section .like-bnr {
    display: block;
    position: relative;
    height: 250px;
    min-height: 250px;
    background: #f5f5f5 url({{ 'week-sale-bg-1-1.jpg' | asset_url }}) right top no-repeat;
    background-size: cover;
  }

  #shopify-section-{{ section.id }} .promo-tile-row-section .like-bnr.watch {
    background: #f5f5f5 url({{ 'week-sale-bg-1-2.jpg' | asset_url }}) right top no-repeat;
    background-size: cover;
  }

  #shopify-section-{{ section.id }} .promo-tile-row-section .like-bnr .position-center-center {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    padding-left: 25px;
  }

  #shopify-section-{{ section.id }} .promo-tile-row-section .like-bnr h5 {
    color: #888888;
    margin: 0;
    font-size: 20px;
    line-height: 24px;
    font-weight: 400;
  }

  #shopify-section-{{ section.id }} .promo-tile-row-section .like-bnr h4 {
    color: #22c961;
    font-size: 26px;
    font-weight: 600;
    letter-spacing: -1px;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .promo-tile-row-section .like-bnr .price {
    color: #222222;
    font-size: 26px;
    font-weight: 800;
  }

  #shopify-section-{{ section.id }} .promo-tile-row-section .promo-tile-btn {
    display: inline-block;
    margin-top: 14px;
    padding: 8px 24px;
    font-size: 14px;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .promo-tile-row-section .week-sale-bnr {
    height: 250px;
    text-align: center;
    padding: 50px 35px 0;
    background: url({{ 'week-sale-bg-1.jpg' | asset_url }}) center center no-repeat;
    background-size: cover;
  }

  #shopify-section-{{ section.id }} .promo-tile-row-section .week-sale-bnr h4 {
    color: #ffffff;
    font-size: 30px;
    margin: 0 0 5px;
  }

  #shopify-section-{{ section.id }} .promo-tile-row-section .week-sale-bnr h4 span {
    color: #000000;
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .promo-tile-row-section .week-sale-bnr p {
    color: #ffffff;
    font-size: 20px;
    line-height: 24px;
    margin-bottom: 20px;
    opacity: 0.9;
  }

  @media (max-width: 991px) {
    #shopify-section-{{ section.id }} .promo-tile-row-section .col-md-4 {
      margin-bottom: 20px;
    }

    #shopify-section-{{ section.id }} .promo-tile-row-section .col-md-4:last-child {
      margin-bottom: 0;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Promo Tile Row",
  "blocks": [
    {
      "type": "promo_tile",
      "name": "Promo tile",
      "settings": [
        {
          "type": "select",
          "id": "tile_variant",
          "label": "Tile style",
          "default": "regular",
          "options": [
            {
              "value": "regular",
              "label": "Regular"
            },
            {
              "value": "watch",
              "label": "Watch"
            },
            {
              "value": "sale",
              "label": "Sale banner"
            }
          ]
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "New line required"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Z68 Web Camera"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "$85.00"
        },
        {
          "type": "image_picker",
          "id": "tile_background_image",
          "label": "Tile background image"
        },
        {
          "type": "text",
          "id": "highlight",
          "label": "Highlighted text",
          "default": "Sale!"
        },
        {
          "type": "textarea",
          "id": "body_text",
          "label": "Body text",
          "default": "Saving up to 50% off all online store items this week."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Promo Tile Row",
      "blocks": [
        {
          "type": "promo_tile",
          "settings": {
            "tile_variant": "regular",
            "subtitle": "New line required",
            "title": "Z68 Web Camera",
            "price": "$85.00"
          }
        },
        {
          "type": "promo_tile",
          "settings": {
            "tile_variant": "watch",
            "subtitle": "No restocking fee ($35 savings)",
            "title": "SmartPhone",
            "price": "$450.00"
          }
        },
        {
          "type": "promo_tile",
          "settings": {
            "tile_variant": "sale",
            "title": "Huge",
            "highlight": "Sale!",
            "body_text": "Saving up to 50% off all online store items this week.",
            "button_label": "Shop now"
          }
        }
      ]
    }
  ]
}
{% endschema %}
