{%- liquid
  assign featured_collection = section.settings.featured_collection
  assign special_collection = section.settings.special_collection
  assign onsale_collection = section.settings.onsale_collection
  assign featured_tab_id = 'featur-' | append: section.id
  assign special_tab_id = 'special-' | append: section.id
  assign onsale_tab_id = 'on-sal-' | append: section.id
-%}

<!-- tab Section -->
<section class="featur-tabs padding-top-20 padding-bottom-60">
  <div class="container">
    <ul class="nav nav-tabs nav-bars margin-bottom-40" role="tablist">
      <li role="presentation" class="active"><a href="#{{ featured_tab_id }}" aria-controls="{{ featured_tab_id }}" role="tab" data-toggle="tab">{{ section.settings.featured_tab_label }}</a></li>
      <li role="presentation"><a href="#{{ special_tab_id }}" aria-controls="{{ special_tab_id }}" role="tab" data-toggle="tab">{{ section.settings.special_tab_label }}</a></li>
      <li role="presentation"><a href="#{{ onsale_tab_id }}" aria-controls="{{ onsale_tab_id }}" role="tab" data-toggle="tab">{{ section.settings.onsale_tab_label }}</a></li>
    </ul>

    <div class="tab-content">
      <div role="tabpanel" class="tab-pane active fade in" id="{{ featured_tab_id }}">
        <div class="item-slide-4 with-nav">
          {% if featured_collection != blank and featured_collection.products_count > 0 %}
            {% for product in featured_collection.products limit: section.settings.featured_products_limit %}
              {% render 'product-card', product: product %}
            {% endfor %}
          {% else %}
            {% render 'product-card', fallback_image: 'item-img-1-1.jpg', fallback_tag: 'Latop', fallback_title: 'Laptop Alienware 15 i7 Perfect For Playing Game', fallback_price: '$350.00' %}
            {% render 'product-card', fallback_image: 'item-img-1-2.jpg', fallback_tag: 'Tablets', fallback_title: 'Mp3 Sumergible Deportivo Slim Con 8GB', fallback_price: '$350.00', fallback_compare_price: '$200.00' %}
            {% render 'product-card', fallback_image: 'item-img-1-3.jpg', fallback_tag: 'Appliances', fallback_title: 'Reloj Inteligente Smart Watch M26 Touch Bluetooh', fallback_price: '$350.00' %}
            {% render 'product-card', fallback_image: 'item-img-1-4.jpg', fallback_tag: 'Accessories', fallback_title: 'Teclado Inalambrico Bluetooth Con Air Mouse', fallback_price: '$350.00' %}
            {% render 'product-card', fallback_image: 'item-img-1-5.jpg', fallback_tag: 'Appliances', fallback_title: 'Mp3 Sumergible Deportivo Slim Con 8GB', fallback_price: '$350.00' %}
            {% render 'product-card', fallback_image: 'item-img-1-6.jpg', fallback_tag: 'Tablets', fallback_title: 'Mp3 Sumergible Deportivo Slim Con 8GB', fallback_price: '$350.00', fallback_compare_price: '$200.00' %}
            {% render 'product-card', fallback_image: 'item-img-1-7.jpg', fallback_tag: 'Appliances', fallback_title: 'Reloj Inteligente Smart Watch M26 Touch Bluetooh', fallback_price: '$350.00' %}
            {% render 'product-card', fallback_image: 'item-img-1-8.jpg', fallback_tag: 'Accessories', fallback_title: 'Teclado Inalambrico Bluetooth Con Air Mouse', fallback_price: '$350.00' %}
          {% endif %}
        </div>
      </div>

      <div role="tabpanel" class="tab-pane fade" id="{{ special_tab_id }}">
        <div class="item-col-4">
          {% if special_collection != blank and special_collection.products_count > 0 %}
            {% for product in special_collection.products limit: section.settings.special_products_limit %}
              {% render 'product-card', product: product %}
            {% endfor %}
          {% else %}
            {% render 'product-card', fallback_image: 'item-img-1-9.jpg', fallback_tag: 'Tablets', fallback_title: 'Mp3 Sumergible Deportivo Slim Con 8GB', fallback_price: '$350.00', fallback_compare_price: '$200.00' %}
            {% render 'product-card', fallback_image: 'item-img-1-8.jpg', fallback_tag: 'Appliances', fallback_title: 'Reloj Inteligente Smart Watch M26 Touch Bluetooh', fallback_price: '$350.00' %}
            {% render 'product-card', fallback_image: 'item-img-1-7.jpg', fallback_tag: 'Accessories', fallback_title: 'Teclado Inalambrico Bluetooth Con Air Mouse', fallback_price: '$350.00' %}
            {% render 'product-card', fallback_image: 'item-img-1-6.jpg', fallback_tag: 'Appliances', fallback_title: 'Mp3 Sumergible Deportivo Slim Con 8GB', fallback_price: '$350.00' %}
          {% endif %}
        </div>
      </div>

      <div role="tabpanel" class="tab-pane fade" id="{{ onsale_tab_id }}">
        <div class="item-col-4">
          {% if onsale_collection != blank and onsale_collection.products_count > 0 %}
            {%- liquid
              assign onsale_count = 0
            -%}
            {% for product in onsale_collection.products %}
              {% if product.compare_at_price > product.price %}
                {% render 'product-card', product: product %}
                {%- liquid
                  assign onsale_count = onsale_count | plus: 1
                -%}
              {% endif %}
              {% if onsale_count >= section.settings.onsale_products_limit %}
                {% break %}
              {% endif %}
            {% endfor %}
            {% if onsale_count == 0 %}
              {% for product in onsale_collection.products limit: section.settings.onsale_products_limit %}
                {% render 'product-card', product: product %}
              {% endfor %}
            {% endif %}
          {% else %}
            {% render 'product-card', fallback_image: 'item-img-1-1.jpg', fallback_tag: 'Tablets', fallback_title: 'Mp3 Sumergible Deportivo Slim Con 8GB', fallback_price: '$350.00', fallback_compare_price: '$200.00' %}
            {% render 'product-card', fallback_image: 'item-img-1-2.jpg', fallback_tag: 'Appliances', fallback_title: 'Reloj Inteligente Smart Watch M26 Touch Bluetooh', fallback_price: '$350.00' %}
            {% render 'product-card', fallback_image: 'item-img-1-5.jpg', fallback_tag: 'Accessories', fallback_title: 'Teclado Inalambrico Bluetooth Con Air Mouse', fallback_price: '$350.00' %}
            {% render 'product-card', fallback_image: 'item-img-1-4.jpg', fallback_tag: 'Appliances', fallback_title: 'Funda Para Ebook 7\" 128GB full HD', fallback_price: '$350.00' %}
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection Tabs",
  "settings": [
    {
      "type": "text",
      "id": "featured_tab_label",
      "label": "Featured tab label",
      "default": "Featured"
    },
    {
      "type": "text",
      "id": "special_tab_label",
      "label": "Special tab label",
      "default": "Special"
    },
    {
      "type": "text",
      "id": "onsale_tab_label",
      "label": "On sale tab label",
      "default": "Onsale"
    },
    {
      "type": "collection",
      "id": "featured_collection",
      "label": "Featured collection"
    },
    {
      "type": "collection",
      "id": "special_collection",
      "label": "Special collection"
    },
    {
      "type": "collection",
      "id": "onsale_collection",
      "label": "On sale collection"
    },
    {
      "type": "range",
      "id": "featured_products_limit",
      "label": "Featured products count",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "special_products_limit",
      "label": "Special products count",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "onsale_products_limit",
      "label": "On sale products count",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Featured Collection Tabs"
    }
  ]
}
{% endschema %}
