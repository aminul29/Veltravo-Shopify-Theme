<section class="collection-tabs section-shell" id="CollectionTabs-{{ section.id }}">
  <div class="page-width">
    <div class="section-heading">
      <h2>
        {% if section.settings.heading != blank %}
          {{ section.settings.heading | escape }}
        {% else %}
          {{ 'sections.featured_collection_tabs.default_heading' | t }}
        {% endif %}
      </h2>
      {% if section.settings.subheading != blank %}
        <p>{{ section.settings.subheading | escape }}</p>
      {% endif %}
    </div>
    <div class="collection-tabs__shell card-surface" data-collection-tabs>
      <div class="collection-tabs__list" role="tablist" aria-label="{{ section.settings.heading | escape }}">
        {% for block in section.blocks %}
          {%- liquid
            assign tab_label = block.settings.label
            if tab_label == blank and block.settings.collection != blank
              assign tab_label = block.settings.collection.title
            endif
            if tab_label == blank
              assign tab_label = 'Collection ' | append: forloop.index
            endif
          -%}
          <button
            class="collection-tabs__tab{% if forloop.first %} is-active{% endif %}"
            type="button"
            role="tab"
            data-collection-tab
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            {{ block.shopify_attributes }}
          >
            {{ tab_label | escape }}
          </button>
        {% endfor %}
      </div>
      <div class="collection-tabs__panels">
        {% for block in section.blocks %}
          <div class="collection-tabs__panel{% if forloop.first %} is-active{% endif %}" data-collection-panel>
            {% if block.settings.collection != blank and block.settings.collection.products_count > 0 %}
              <div class="collection-tabs__grid">
                {% for product in block.settings.collection.products limit: block.settings.product_limit %}
                  {% render 'product-card', product: product, show_vendor: section.settings.show_vendor %}
                {% endfor %}
              </div>
            {% else %}
              <p class="collection-tabs__empty">{{ 'general.empty.collection' | t }}</p>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .collection-tabs__shell {
    padding: 1rem;
  }

  .collection-tabs__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .collection-tabs__tab {
    border: 0;
    border-radius: 999px;
    padding: 0.8rem 1.1rem;
    background: color-mix(in srgb, var(--color-text) 8%, transparent);
    color: var(--color-text);
    font-weight: 700;
  }

  .collection-tabs__tab.is-active {
    background: var(--color-accent);
    color: #ffffff;
  }

  .collection-tabs__panel {
    display: none;
  }

  .collection-tabs__panel.is-active {
    display: block;
  }

  .collection-tabs__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .collection-tabs__empty {
    margin: 0;
    padding: 1rem;
  }

  @media screen and (max-width: 989px) {
    .collection-tabs__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .collection-tabs__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% javascript %}
  (() => {
    const sectionRoot = document.currentScript.closest('.shopify-section')
    const host = sectionRoot?.querySelector('[data-collection-tabs]')
    if (!host) return
    const tabs = [...host.querySelectorAll('[data-collection-tab]')]
    const panels = [...host.querySelectorAll('[data-collection-panel]')]
    tabs.forEach((tab, index) => {
      tab.addEventListener('click', () => {
        tabs.forEach((button, buttonIndex) => {
          const active = buttonIndex === index
          button.classList.toggle('is-active', active)
          button.setAttribute('aria-selected', active ? 'true' : 'false')
          panels[buttonIndex]?.classList.toggle('is-active', active)
        })
      })
    })
  })()
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.featured_collection_tabs.name",
  "class": "section-featured-collection-tabs",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:labels.subheading"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:labels.show_vendor",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "collection_tab",
      "name": "t:sections.featured_collection_tabs.name",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:labels.collection"
        },
        {
          "type": "text",
          "id": "label",
          "label": "t:labels.collection_label"
        },
        {
          "type": "range",
          "id": "product_limit",
          "label": "t:labels.product_limit",
          "min": 2,
          "max": 8,
          "step": 1,
          "default": 4
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "t:sections.featured_collection_tabs.name",
      "blocks": [
        {
          "type": "collection_tab"
        },
        {
          "type": "collection_tab"
        },
        {
          "type": "collection_tab"
        }
      ]
    }
  ]
}
{% endschema %}
