{%- liquid
  assign categories_menu = section.settings.categories_menu
-%}

<!-- Slid Sec -->
<section class="slid-sec">
  <div class="container">
    <div class="container-fluid">
      <div class="row">
        <div class="col-md-3 no-padding">
          <div class="cate-bar-in relative margin-top-0">
            <div id="cater">
              <ul>
                {% if categories_menu != blank and categories_menu.links.size > 0 %}
                  {% for link in categories_menu.links %}
                    {% if link.links != blank and link.links.size > 0 %}
                      <li class="sub-menu">
                        <a href="{{ link.url }}">{{ link.title | escape }}</a>
                        <ul>
                          {% for child_link in link.links %}
                            <li><a href="{{ child_link.url }}">{{ child_link.title | escape }}</a></li>
                          {% endfor %}
                        </ul>
                      </li>
                    {% else %}
                      <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
                    {% endif %}
                  {% endfor %}
                {% endif %}
              </ul>
            </div>
          </div>
        </div>

        <div class="col-md-9 no-padding">
          {%- liquid
            assign merchandising_collection = section.settings.merch_collection
            assign slides_limit = section.settings.products_to_show | default: 3
            assign slide_button_label = section.settings.button_label | default: 'Shop Now'
            assign slide_overlay_color = section.settings.overlay_color | default: '#000000'
            assign slide_overlay_opacity = section.settings.overlay_opacity | default: 35 | divided_by: 100.0
            assign slider_height = section.settings.slider_height | default: 500
            assign slider_delay_ms = section.settings.slider_delay_seconds | default: 9 | times: 1000

            if merchandising_collection == blank or merchandising_collection.products_count == 0
              assign merchandising_collection = collections['all']
            endif
          -%}
          <div class="hhm-swiper-wrap">
            <div
              id="hhm-swiper-{{ section.id }}"
              class="swiper hhm-swiper"
              data-autoplay="{{ section.settings.slider_autoplay }}"
              data-delay="{{ slider_delay_ms }}"
              data-show-arrows="{{ section.settings.show_arrows }}"
              data-show-bullets="{{ section.settings.show_bullets }}"
            >
              <div class="swiper-wrapper">
                {% if merchandising_collection != blank and merchandising_collection.products_count > 0 %}
                  {% for slide_product in merchandising_collection.products limit: slides_limit %}
                    {%- liquid
                      if slide_product.featured_image != blank
                        assign slide_background_image = slide_product.featured_image | image_url: width: 2200
                      else
                        assign slide_background_image = 'trans-bg.png' | asset_url
                      endif

                      assign slide_pretitle = slide_product.vendor | default: slide_product.type
                      assign slide_price_text = slide_product.selected_or_first_available_variant.price | money
                    -%}
                    <div
                      class="swiper-slide home-hero-merchandising-slide"
                      style="background-image: url('{{ slide_background_image }}');"
                    >
                      <div class="hero-slide-overlay" style="background-color: {{ slide_overlay_color }}; opacity: {{ slide_overlay_opacity }};"></div>
                      <div class="hhm-slide-content">
                        <div class="hhm-pretitle">{{ slide_pretitle }}</div>
                        <h2 class="hhm-title">{{ slide_product.title }}</h2>
                        <div class="hhm-price">{{ slide_price_text }}</div>
                        <a href="{{ slide_product.url }}" class="btn-round big hhm-button">{{ slide_button_label }}</a>
                      </div>
                    </div>
                  {% endfor %}
                {% else %}
                  <div
                    class="swiper-slide home-hero-merchandising-slide"
                    style="background-image: url('{{ 'trans-bg.png' | asset_url }}');"
                  >
                    <div class="hero-slide-overlay" style="background-color: {{ slide_overlay_color }}; opacity: {{ slide_overlay_opacity }};"></div>
                    <div class="hhm-slide-content">
                      <div class="hhm-pretitle">Select a collection</div>
                      <h2 class="hhm-title">Home Hero Merchandising</h2>
                      <a href="{{ routes.collections_url }}" class="btn-round big hhm-button">{{ slide_button_label }}</a>
                    </div>
                  </div>
                {% endif %}
              </div>

              {% if section.settings.show_arrows %}
                <div class="swiper-button-prev hhm-swiper-prev"></div>
                <div class="swiper-button-next hhm-swiper-next"></div>
              {% endif %}
              {% if section.settings.show_bullets %}
                <div class="swiper-pagination hhm-swiper-pagination"></div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% style %}
  #shopify-section-{{ section.id }} .hhm-swiper {
    height: {{ slider_height }}px;
  }

  #shopify-section-{{ section.id }} .home-hero-merchandising-slide {
    position: relative;
    min-height: {{ slider_height }}px;
    background-position: center center;
    background-size: cover;
    background-repeat: no-repeat;
    display: flex;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .home-hero-merchandising-slide .hero-slide-overlay {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 2;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .hhm-slide-content {
    position: relative;
    z-index: 3;
    max-width: 46%;
    margin-left: auto;
    margin-right: 48px;
    padding-right: 24px;
  }

  #shopify-section-{{ section.id }} .hhm-pretitle {
    color: {{ section.settings.pretitle_color }};
    font-size: {{ section.settings.pretitle_size }}px;
    font-weight: 500;
    margin-bottom: 10px;
  }

  #shopify-section-{{ section.id }} .hhm-title {
    color: {{ section.settings.title_color }};
    font-size: {{ section.settings.title_size }}px;
    font-weight: 800;
    line-height: 1.15;
    margin: 0 0 16px;
    white-space: normal;
    overflow: visible;
    text-overflow: clip;
  }

  #shopify-section-{{ section.id }} .hhm-price {
    color: {{ section.settings.price_color }};
    font-size: {{ section.settings.price_size }}px;
    font-weight: 800;
    margin-bottom: 24px;
  }

  #shopify-section-{{ section.id }} .hhm-button {
    display: inline-block;
    color: {{ section.settings.button_text_color }};
    background: {{ section.settings.button_bg_color }};
    border-color: {{ section.settings.button_bg_color }};
    border-radius: {{ section.settings.button_radius }}px;
  }

  #shopify-section-{{ section.id }} .hhm-button:hover,
  #shopify-section-{{ section.id }} .hhm-button:focus {
    color: {{ section.settings.button_text_hover_color }};
    background: {{ section.settings.button_bg_hover_color }};
    border-color: {{ section.settings.button_bg_hover_color }};
  }

  #shopify-section-{{ section.id }} .hhm-swiper .swiper-button-prev,
  #shopify-section-{{ section.id }} .hhm-swiper .swiper-button-next {
    color: #ffffff;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.35);
  }

  #shopify-section-{{ section.id }} .hhm-swiper .swiper-button-prev::after,
  #shopify-section-{{ section.id }} .hhm-swiper .swiper-button-next::after {
    font-size: 16px;
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .hhm-swiper .swiper-pagination-bullet {
    background: #ffffff;
    opacity: 0.6;
  }

  #shopify-section-{{ section.id }} .hhm-swiper .swiper-pagination-bullet-active {
    opacity: 1;
  }

  @media (max-width: 1199px) {
    #shopify-section-{{ section.id }} .hhm-slide-content {
      max-width: 52%;
      margin-right: 32px;
      padding-right: 0;
    }
  }

  @media (max-width: 991px) {
    #shopify-section-{{ section.id }} .hhm-swiper {
      height: auto;
      min-height: {{ slider_height }}px;
    }

    #shopify-section-{{ section.id }} .home-hero-merchandising-slide {
      min-height: {{ slider_height }}px;
      align-items: flex-end;
    }

    #shopify-section-{{ section.id }} .hhm-slide-content {
      max-width: 100%;
      margin: 0;
      padding: 28px 22px;
    }

    #shopify-section-{{ section.id }} .hhm-title {
      font-size: {{ section.settings.title_size | minus: 6 }}px;
    }
  }

  @media (max-width: 575px) {
    #shopify-section-{{ section.id }} .home-hero-merchandising-slide {
      min-height: 360px;
    }

    #shopify-section-{{ section.id }} .hhm-title {
      font-size: {{ section.settings.title_size | minus: 10 }}px;
    }

    #shopify-section-{{ section.id }} .hhm-pretitle {
      font-size: {{ section.settings.pretitle_size | minus: 4 }}px;
    }

    #shopify-section-{{ section.id }} .hhm-price {
      font-size: {{ section.settings.price_size | minus: 8 }}px;
    }
  }
{% endstyle %}

<script>
  (function () {
    var sectionId = '{{ section.id }}';
    var sectionSelector = '#shopify-section-' + sectionId;
    var sliderSelector = sectionSelector + ' .hhm-swiper';

    function ensureSwiperAssets(callback) {
      if (window.Swiper) {
        callback();
        return;
      }

      if (!document.getElementById('hhm-swiper-css')) {
        var link = document.createElement('link');
        link.id = 'hhm-swiper-css';
        link.rel = 'stylesheet';
        link.href = 'https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css';
        document.head.appendChild(link);
      }

      var existingScript = document.getElementById('hhm-swiper-js');
      if (existingScript) {
        existingScript.addEventListener('load', callback, { once: true });
        return;
      }

      var script = document.createElement('script');
      script.id = 'hhm-swiper-js';
      script.src = 'https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js';
      script.onload = callback;
      document.body.appendChild(script);
    }

    function initSlider() {
      var slider = document.querySelector(sliderSelector);
      if (!slider || !window.Swiper) {
        return;
      }

      if (slider.swiper) {
        slider.swiper.destroy(true, true);
      }

      var delay = parseInt(slider.getAttribute('data-delay'), 10) || 9000;
      var autoplayEnabled = slider.getAttribute('data-autoplay') === 'true';
      var showArrows = slider.getAttribute('data-show-arrows') === 'true';
      var showBullets = slider.getAttribute('data-show-bullets') === 'true';

      new window.Swiper(slider, {
        slidesPerView: 1,
        loop: true,
        speed: 700,
        autoplay: autoplayEnabled
          ? {
              delay: delay,
              disableOnInteraction: false,
              pauseOnMouseEnter: true
            }
          : false,
        navigation: showArrows
          ? {
              nextEl: sectionSelector + ' .hhm-swiper-next',
              prevEl: sectionSelector + ' .hhm-swiper-prev'
            }
          : false,
        pagination: showBullets
          ? {
              el: sectionSelector + ' .hhm-swiper-pagination',
              clickable: true
            }
          : false
      });
    }

    function initSection() {
      ensureSwiperAssets(initSlider);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initSection);
    } else {
      initSection();
    }

    document.addEventListener('shopify:section:load', function (event) {
      if (event.detail && event.detail.sectionId === sectionId) {
        initSection();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Home Hero Merchandising",
  "settings": [
    {
      "type": "link_list",
      "id": "categories_menu",
      "label": "Categories menu"
    },
    {
      "type": "collection",
      "id": "merch_collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Number of slides",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "slider_autoplay",
      "label": "Auto-rotate slides",
      "default": true
    },
    {
      "type": "range",
      "id": "slider_delay_seconds",
      "label": "Slide rotation delay",
      "min": 3,
      "max": 15,
      "step": 1,
      "unit": "s",
      "default": 9
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_bullets",
      "label": "Show bullets",
      "default": true
    },
    {
      "type": "range",
      "id": "slider_height",
      "label": "Slider height",
      "min": 380,
      "max": 700,
      "step": 10,
      "unit": "px",
      "default": 500
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 35
    },
    {
      "type": "color",
      "id": "pretitle_color",
      "label": "Pretitle color",
      "default": "#888888"
    },
    {
      "type": "range",
      "id": "pretitle_size",
      "label": "Pretitle size",
      "min": 14,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 26
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#22c961"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 20,
      "max": 64,
      "step": 1,
      "unit": "px",
      "default": 36
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "price_size",
      "label": "Price size",
      "min": 20,
      "max": 64,
      "step": 1,
      "unit": "px",
      "default": 36
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background",
      "default": "#22c961"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_bg_hover_color",
      "label": "Button hover background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "button_text_hover_color",
      "label": "Button hover text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Button radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 30
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    }
  ],
  "presets": [
    {
      "name": "Home Hero Merchandising"
    }
  ]
}
{% endschema %}
