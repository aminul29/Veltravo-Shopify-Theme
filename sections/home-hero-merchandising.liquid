<section class="hero-merch section-shell" id="HeroMerch-{{ section.id }}">
  <div class="page-width hero-merch__grid">
    <aside class="hero-merch__categories card-surface">
      <p class="hero-merch__categories-title">{{ 'general.header.categories' | t }}</p>
      {% if section.settings.category_menu != blank %}
        <ul class="list-reset hero-merch__category-list">
          {% for link in section.settings.category_menu.links %}
            <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
          {% endfor %}
        </ul>
      {% else %}
        <p class="hero-merch__empty">{{ 'general.empty.menu' | t }}</p>
      {% endif %}
    </aside>

    <div
      class="hero-merch__carousel card-surface"
      data-hero-carousel
      data-auto-rotate="{{ section.settings.auto_rotate }}"
      data-rotation-seconds="{{ section.settings.rotation_seconds }}"
    >
      {% if section.blocks.size > 0 %}
        <div class="hero-merch__track" data-hero-track>
          {% for block in section.blocks %}
            {%- liquid
              assign slide_eyebrow = block.settings.eyebrow
              assign slide_heading = block.settings.heading
              assign slide_text = block.settings.text
              assign slide_button = block.settings.button_label
              if slide_eyebrow == blank
                assign slide_eyebrow = 'sections.hero.default_eyebrow' | t
              endif
              if slide_heading == blank
                assign slide_heading = 'sections.hero.default_heading' | t
              endif
              if slide_text == blank
                assign slide_text = 'sections.hero.default_text' | t
              endif
              if slide_button == blank
                assign slide_button = 'sections.hero.default_button' | t
              endif
            -%}
            <article
              class="hero-merch__slide"
              data-hero-slide
              style="--slide-accent: {{ block.settings.accent_color | default: settings.color_accent }}; --slide-bg: {{ block.settings.background_color | default: '#eef4ff' }};"
              {{ block.shopify_attributes }}
            >
              <div class="hero-merch__copy">
                <p class="section-heading__eyebrow">{{ slide_eyebrow | escape }}</p>
                <h2>{{ slide_heading | escape }}</h2>
                <p>{{ slide_text | escape }}</p>
                {% if block.settings.button_link != blank %}
                  <a class="button" href="{{ block.settings.button_link }}">{{ slide_button | escape }}</a>
                {% else %}
                  <span class="button">{{ slide_button | escape }}</span>
                {% endif %}
              </div>
              <div class="hero-merch__media">
                {% if block.settings.image != blank %}
                  {{
                    block.settings.image
                    | image_url: width: 900
                    | image_tag: loading: 'lazy', widths: '400, 700, 900', alt: slide_heading | escape
                  }}
                {% else %}
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'hero-merch__placeholder' }}
                {% endif %}
              </div>
            </article>
          {% endfor %}
        </div>
        {% if section.blocks.size > 1 %}
          <div class="hero-merch__controls">
            <button class="button button--ghost" type="button" data-hero-prev>&larr;</button>
            <div class="hero-merch__dots" aria-label="{{ 'general.header.menu' | t }}">
              {% for block in section.blocks %}
                <button
                  class="hero-merch__dot{% if forloop.first %} is-active{% endif %}"
                  type="button"
                  data-hero-dot
                  aria-label="{{ forloop.index }}"
                ></button>
              {% endfor %}
            </div>
            <button class="button button--ghost" type="button" data-hero-next>&rarr;</button>
          </div>
        {% endif %}
      {% else %}
        <div class="hero-merch__empty">{{ 'general.empty.slides' | t }}</div>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .hero-merch__grid {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 1.25rem;
  }

  .hero-merch__categories,
  .hero-merch__carousel {
    overflow: hidden;
  }

  .hero-merch__categories {
    padding: 1.25rem;
  }

  .hero-merch__categories-title {
    margin: 0 0 1rem;
    font-weight: 800;
  }

  .hero-merch__category-list {
    display: grid;
    gap: 0.85rem;
  }

  .hero-merch__category-list a {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    color: color-mix(in srgb, var(--color-text) 78%, transparent);
  }

  .hero-merch__track {
    display: flex;
    transition: transform 0.35s ease;
  }

  .hero-merch__slide {
    flex: 0 0 100%;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 42%);
    gap: 1rem;
    align-items: center;
    padding: 2rem;
    background: radial-gradient(circle at top left, color-mix(in srgb, var(--slide-accent) 18%, white), var(--slide-bg));
  }

  .hero-merch__copy {
    display: grid;
    gap: 1rem;
  }

  .hero-merch__copy h2 {
    margin: 0;
    font-size: clamp(2rem, 1.2rem + 2.4vw, 3.8rem);
    line-height: 1.02;
  }

  .hero-merch__copy p {
    margin: 0;
    max-width: 50ch;
  }

  .hero-merch__media {
    justify-self: end;
    width: min(100%, 460px);
  }

  .hero-merch__media img,
  .hero-merch__placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 1.5rem;
  }

  .hero-merch__placeholder {
    padding: 2rem;
  }

  .hero-merch__controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem 1.25rem;
  }

  .hero-merch__dots {
    display: flex;
    gap: 0.5rem;
  }

  .hero-merch__dot {
    width: 0.8rem;
    height: 0.8rem;
    border: 0;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-text) 18%, transparent);
  }

  .hero-merch__dot.is-active {
    background: var(--color-accent);
  }

  .hero-merch__empty {
    padding: 2rem;
  }

  @media screen and (max-width: 989px) {
    .hero-merch__grid {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    .hero-merch__slide {
      grid-template-columns: 1fr;
      padding: 1.25rem;
    }

    .hero-merch__media {
      justify-self: stretch;
      width: 100%;
    }
  }
{% endstylesheet %}

{% javascript %}
  (() => {
    const sectionRoot = document.currentScript.closest('.shopify-section')
    const carousel = sectionRoot?.querySelector('[data-hero-carousel]')
    const track = carousel?.querySelector('[data-hero-track]')
    if (!carousel || !track) return
    const slides = [...carousel.querySelectorAll('[data-hero-slide]')]
    const dots = [...carousel.querySelectorAll('[data-hero-dot]')]
    const prev = carousel.querySelector('[data-hero-prev]')
    const next = carousel.querySelector('[data-hero-next]')
    if (!slides.length) return

    let index = 0
    const update = (newIndex) => {
      index = (newIndex + slides.length) % slides.length
      track.style.transform = `translateX(-${index * 100}%)`
      dots.forEach((dot, dotIndex) => dot.classList.toggle('is-active', dotIndex === index))
    }

    prev?.addEventListener('click', () => update(index - 1))
    next?.addEventListener('click', () => update(index + 1))
    dots.forEach((dot, dotIndex) => dot.addEventListener('click', () => update(dotIndex)))

    if (slides.length > 1 && carousel.dataset.autoRotate === 'true') {
      const delay = Math.max(Number(carousel.dataset.rotationSeconds || 5) * 1000, 3000)
      window.setInterval(() => update(index + 1), delay)
    }
  })()
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.home_hero_merchandising.name",
  "class": "section-home-hero-merchandising",
  "settings": [
    {
      "type": "link_list",
      "id": "category_menu",
      "label": "t:labels.category_menu"
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "t:labels.auto_rotate",
      "default": true
    },
    {
      "type": "range",
      "id": "rotation_seconds",
      "label": "t:labels.rotation_seconds",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "t:sections.home_hero_merchandising.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "t:labels.eyebrow"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:labels.heading"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "t:labels.text"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "t:labels.button_label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "t:labels.button_link"
        },
        {
          "type": "color",
          "id": "accent_color",
          "label": "t:labels.accent_color",
          "default": "#1f6df0"
        },
        {
          "type": "color",
          "id": "background_color",
          "label": "t:labels.background_color",
          "default": "#eef4ff"
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "t:sections.home_hero_merchandising.name",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
