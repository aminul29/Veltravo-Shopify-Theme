{%- liquid
  assign categories_menu = section.settings.categories_menu
-%}

<!-- Slid Sec -->
<section class="slid-sec">
  <div class="container">
    <div class="container-fluid">
      <div class="row">
        <div class="col-md-3 no-padding">
          <div class="cate-bar-in relative margin-top-0">
            <div id="cater">
              <ul>
                {% if categories_menu != blank and categories_menu.links.size > 0 %}
                  {% for link in categories_menu.links %}
                    {% if link.links != blank and link.links.size > 0 %}
                      <li class="sub-menu">
                        <a href="{{ link.url }}">{{ link.title | escape }}</a>
                        <ul>
                          {% for child_link in link.links %}
                            <li><a href="{{ child_link.url }}">{{ child_link.title | escape }}</a></li>
                          {% endfor %}
                        </ul>
                      </li>
                    {% else %}
                      <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
                    {% endif %}
                  {% endfor %}
                {% endif %}
              </ul>
            </div>
          </div>
        </div>

        <div class="col-md-9 no-padding">
          <div class="tp-banner-container">
            <div class="tp-banner with-bg-slide-all">
              <ul>
                {% assign product_slides_count = 0 %}
                {% for block in section.blocks %}
                  {% if block.settings.product != blank %}
                    {% assign product_slides_count = product_slides_count | plus: 1 %}
                  {% endif %}
                {% endfor %}

                {% if product_slides_count > 0 %}
                  {% for block in section.blocks %}
                    {%- liquid
                      assign slide_product = block.settings.product
                      if slide_product == blank
                        continue
                      endif

                      assign layer_image = block.settings.foreground_image
                      if layer_image == blank
                        if slide_product.featured_image != blank
                          assign layer_image = slide_product.featured_image | image_url: width: 900
                        else
                          if forloop.index == 2
                            assign layer_image = 'slide-item-9-1.png'
                          else
                            assign layer_image = 'slide-item-7-2.png'
                          endif
                        endif
                      endif

                      assign slide_pretitle = slide_product.vendor | default: slide_product.type
                      if block.settings.pretitle != blank
                        assign slide_pretitle = block.settings.pretitle
                      endif

                      assign slide_title = slide_product.title
                      if block.settings.title != blank
                        assign slide_title = block.settings.title
                      endif

                      assign slide_price_text = slide_product.selected_or_first_available_variant.price | money
                      if block.settings.price_text != blank
                        assign slide_price_text = block.settings.price_text
                      endif

                      assign slide_button_link = block.settings.button_link
                      if slide_button_link == blank
                        assign slide_button_link = slide_product.url
                      endif
                    -%}
                    <li data-transition="random" data-slotamount="7" data-masterspeed="300" data-saveperformance="off" {{ block.shopify_attributes }}>
                      {% if block.settings.background_image != blank %}
                        <img src="{{ block.settings.background_image | image_url: width: 1600 }}" alt="{{ slide_title | escape }}" data-bgposition="center bottom" data-bgfit="cover" data-bgrepeat="no-repeat">
                      {% else %}
                        <img src="{{ 'trans-bg.png' | asset_url }}" alt="slider" data-bgposition="center bottom" data-bgfit="cover" data-bgrepeat="no-repeat">
                      {% endif %}

                      <div class="tp-caption sfl tp-resizeme" data-x="left" data-hoffset="550" data-y="center" data-voffset="-80" data-speed="800" data-start="800" data-easing="Power3.easeInOut" data-splitin="chars" data-splitout="none" data-elementdelay="0.03" data-endelementdelay="0.4" data-endspeed="300" style="z-index: 5; font-size:26px; font-weight:500; color:#888888;  max-width: auto; max-height: auto; white-space: nowrap;">{{ slide_pretitle }}</div>
                      <div class="tp-caption sfr tp-resizeme" data-x="left" data-hoffset="550" data-y="center" data-voffset="-40" data-speed="800" data-start="1000" data-easing="Power3.easeInOut" data-splitin="chars" data-splitout="none" data-elementdelay="0.03" data-endelementdelay="0.1" data-endspeed="300" style="z-index: 6; font-size:36px; color:#22c961; font-weight:800; white-space: nowrap;">{{ slide_title }}</div>
                      <div class="tp-caption sfr tp-resizeme" data-x="left" data-hoffset="550" data-y="center" data-voffset="10" data-speed="800" data-start="1300" data-easing="Power3.easeInOut" data-splitin="chars" data-splitout="none" data-elementdelay="0.03" data-endelementdelay="0.4" data-endspeed="300" style="z-index: 5; font-size:36px; font-weight:800; color:#000;  max-width: auto; max-height: auto; white-space: nowrap;">{{ slide_price_text }}</div>
                      <div class="tp-caption sfl tp-resizeme" data-x="left" data-hoffset="{{ block.settings.image_offset }}" data-y="center" data-voffset="0" data-speed="800" data-start="1300" data-easing="Power3.easeInOut" data-elementdelay="0.1" data-endelementdelay="0.1" data-endspeed="300" data-scrolloffset="0" style="z-index: 1;"><img src="{% if block.settings.foreground_image != blank %}{{ block.settings.foreground_image | image_url: width: 900 }}{% else %}{% if slide_product.featured_image != blank %}{{ layer_image }}{% else %}{{ layer_image | asset_url }}{% endif %}{% endif %}" alt="{{ slide_title | escape }}"></div>
                      <div class="tp-caption lfb tp-resizeme" data-x="left" data-hoffset="550" data-y="center" data-voffset="100" data-speed="800" data-start="1300" data-easing="Power3.easeInOut" data-elementdelay="0.1" data-endelementdelay="0.1" data-endspeed="300" data-scrolloffset="0" style="z-index: 8;"><a href="{{ slide_button_link | default: '#.' }}" class="btn-round big">{{ block.settings.button_label }}</a></div>
                    </li>
                  {% endfor %}
                {% else %}
                  {% assign fallback_collection = collections['all'] %}
                  {% if fallback_collection != blank and fallback_collection.products_count > 0 %}
                    {% for fallback_product in fallback_collection.products limit: 3 %}
                      {%- liquid
                        if fallback_product.featured_image != blank
                          assign fallback_layer_image = fallback_product.featured_image | image_url: width: 900
                        else
                          if forloop.index == 2
                            assign fallback_layer_image = 'slide-item-9-1.png' | asset_url
                          else
                            assign fallback_layer_image = 'slide-item-7-2.png' | asset_url
                          endif
                        endif
                      -%}
                      <li data-transition="random" data-slotamount="7" data-masterspeed="300" data-saveperformance="off">
                        <img src="{{ 'trans-bg.png' | asset_url }}" alt="{{ fallback_product.title | escape }}" data-bgposition="center bottom" data-bgfit="cover" data-bgrepeat="no-repeat">
                        <div class="tp-caption sfl tp-resizeme" data-x="left" data-hoffset="550" data-y="center" data-voffset="-80" data-speed="800" data-start="800" data-easing="Power3.easeInOut" data-splitin="chars" data-splitout="none" data-elementdelay="0.03" data-endelementdelay="0.4" data-endspeed="300" style="z-index: 5; font-size:26px; font-weight:500; color:#888888;  max-width: auto; max-height: auto; white-space: nowrap;">{{ fallback_product.vendor | default: fallback_product.type }}</div>
                        <div class="tp-caption sfr tp-resizeme" data-x="left" data-hoffset="550" data-y="center" data-voffset="-40" data-speed="800" data-start="1000" data-easing="Power3.easeInOut" data-splitin="chars" data-splitout="none" data-elementdelay="0.03" data-endelementdelay="0.1" data-endspeed="300" style="z-index: 6; font-size:36px; color:#22c961; font-weight:800; white-space: nowrap;">{{ fallback_product.title }}</div>
                        <div class="tp-caption sfr tp-resizeme" data-x="left" data-hoffset="550" data-y="center" data-voffset="10" data-speed="800" data-start="1300" data-easing="Power3.easeInOut" data-splitin="chars" data-splitout="none" data-elementdelay="0.03" data-endelementdelay="0.4" data-endspeed="300" style="z-index: 5; font-size:36px; font-weight:800; color:#000;  max-width: auto; max-height: auto; white-space: nowrap;">{{ fallback_product.selected_or_first_available_variant.price | money }}</div>
                        <div class="tp-caption sfl tp-resizeme" data-x="left" data-hoffset="50" data-y="center" data-voffset="0" data-speed="800" data-start="1300" data-easing="Power3.easeInOut" data-elementdelay="0.1" data-endelementdelay="0.1" data-endspeed="300" data-scrolloffset="0" style="z-index: 1;"><img src="{{ fallback_layer_image }}" alt="{{ fallback_product.title | escape }}"> </div>
                        <div class="tp-caption lfb tp-resizeme" data-x="left" data-hoffset="550" data-y="center" data-voffset="100" data-speed="800" data-start="1300" data-easing="Power3.easeInOut" data-elementdelay="0.1" data-endelementdelay="0.1" data-endspeed="300" data-scrolloffset="0" style="z-index: 8;"><a href="{{ fallback_product.url }}" class="btn-round big">Shop Now</a> </div>
                      </li>
                    {% endfor %}
                  {% endif %}
                {% endif %}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home Hero Merchandising",
  "settings": [
    {
      "type": "link_list",
      "id": "categories_menu",
      "label": "Categories menu"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "pretitle",
          "label": "Pretitle (optional override)",
          "default": ""
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title (optional override)",
          "default": ""
        },
        {
          "type": "text",
          "id": "price_text",
          "label": "Price text (optional override)",
          "default": ""
        },
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Background image"
        },
        {
          "type": "image_picker",
          "id": "foreground_image",
          "label": "Foreground image"
        },
        {
          "type": "range",
          "id": "image_offset",
          "label": "Foreground horizontal offset",
          "min": 0,
          "max": 300,
          "step": 10,
          "default": 50
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Home Hero Merchandising",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
