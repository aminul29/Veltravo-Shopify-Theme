{%- liquid
  assign categories_menu = section.settings.categories_menu
-%}

<!-- Slid Sec -->
<section class="slid-sec">
  <div class="container">
    <div class="container-fluid">
      <div class="row">
        <div class="col-md-3 no-padding">
          <div class="cate-bar-in relative margin-top-0">
            <div id="cater">
              <ul>
                {% if categories_menu != blank and categories_menu.links.size > 0 %}
                  {% for link in categories_menu.links %}
                    {% if link.links != blank and link.links.size > 0 %}
                      <li class="sub-menu">
                        <a href="{{ link.url }}">{{ link.title | escape }}</a>
                        <ul>
                          {% for child_link in link.links %}
                            <li><a href="{{ child_link.url }}">{{ child_link.title | escape }}</a></li>
                          {% endfor %}
                        </ul>
                      </li>
                    {% else %}
                      <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
                    {% endif %}
                  {% endfor %}
                {% endif %}
              </ul>
            </div>
          </div>
        </div>

        <div class="col-md-9 no-padding">
          {%- liquid
            assign merchandising_collection = section.settings.merch_collection
            assign slides_limit = section.settings.products_to_show | default: 3
            assign slide_button_label = section.settings.button_label | default: 'Shop Now'
            assign slide_image_offset = section.settings.image_offset | default: 50
            assign section_background_image = section.settings.background_image
            assign slide_overlay_color = section.settings.overlay_color | default: '#000000'
            assign slide_overlay_opacity = section.settings.overlay_opacity | default: 35 | divided_by: 100.0
            assign slider_height = section.settings.slider_height | default: 500
            assign slider_delay_ms = section.settings.slider_delay_seconds | default: 9 | times: 1000

            if section.settings.show_bullets
              assign slider_navigation_type = 'bullet'
            else
              assign slider_navigation_type = 'none'
            endif

            if section.settings.show_arrows
              assign slider_navigation_arrows = 'solo'
            else
              assign slider_navigation_arrows = 'none'
            endif

            if merchandising_collection == blank or merchandising_collection.products_count == 0
              assign merchandising_collection = collections['all']
            endif
          -%}
          <div class="tp-banner-container">
            <div
              class="tp-banner with-bg-slide-all"
              data-rev-delay="{{ slider_delay_ms }}"
              data-rev-navigation-type="{{ slider_navigation_type }}"
              data-rev-navigation-arrows="{{ slider_navigation_arrows }}"
              data-rev-gridheight="{{ slider_height }}"
              data-rev-min-height="{{ slider_height }}"
              {% unless section.settings.slider_autoplay %}
                data-rev-stop-loop="on"
                data-rev-stop-at-slide="1"
                data-rev-stop-after-loops="0"
              {% endunless %}
            >
              <ul>
                {% if merchandising_collection != blank and merchandising_collection.products_count > 0 %}
                  {% for slide_product in merchandising_collection.products limit: slides_limit %}
                    {%- liquid
                      if slide_product.featured_image != blank
                        assign slide_background_image = slide_product.featured_image | image_url: width: 2200
                      elsif section_background_image != blank
                        assign slide_background_image = section_background_image | image_url: width: 1600
                      else
                        assign slide_background_image = 'trans-bg.png' | asset_url
                      endif

                      if slide_product.featured_image != blank
                        assign layer_image = slide_product.featured_image | image_url: width: 900
                      else
                        if forloop.index == 2
                          assign layer_image = 'slide-item-9-1.png' | asset_url
                        else
                          assign layer_image = 'slide-item-7-2.png' | asset_url
                        endif
                      endif

                      assign slide_pretitle = slide_product.vendor | default: slide_product.type
                      assign slide_price_text = slide_product.selected_or_first_available_variant.price | money
                    -%}
                    <li class="home-hero-merchandising-slide" data-transition="random" data-slotamount="7" data-masterspeed="300" data-saveperformance="off">
                      <img src="{{ slide_background_image }}" alt="{{ slide_product.title | escape }}" data-bgposition="center center" data-bgfit="cover" data-bgrepeat="no-repeat">
                      <div class="hero-slide-overlay" style="background-color: {{ slide_overlay_color }}; opacity: {{ slide_overlay_opacity }};"></div>

                      <div class="tp-caption sfl tp-resizeme" data-x="left" data-hoffset="550" data-y="center" data-voffset="-80" data-speed="800" data-start="800" data-easing="Power3.easeInOut" data-splitin="chars" data-splitout="none" data-elementdelay="0.03" data-endelementdelay="0.4" data-endspeed="300" style="z-index: 5; font-size:26px; font-weight:500; color:#888888;  max-width: auto; max-height: auto; white-space: nowrap;">{{ slide_pretitle }}</div>
                      <div class="tp-caption sfr tp-resizeme" data-x="left" data-hoffset="550" data-y="center" data-voffset="-40" data-speed="800" data-start="1000" data-easing="Power3.easeInOut" data-splitin="chars" data-splitout="none" data-elementdelay="0.03" data-endelementdelay="0.1" data-endspeed="300" style="z-index: 6; font-size:36px; color:#22c961; font-weight:800; white-space: nowrap;">{{ slide_product.title }}</div>
                      <div class="tp-caption sfr tp-resizeme" data-x="left" data-hoffset="550" data-y="center" data-voffset="10" data-speed="800" data-start="1300" data-easing="Power3.easeInOut" data-splitin="chars" data-splitout="none" data-elementdelay="0.03" data-endelementdelay="0.4" data-endspeed="300" style="z-index: 5; font-size:36px; font-weight:800; color:#000;  max-width: auto; max-height: auto; white-space: nowrap;">{{ slide_price_text }}</div>
                      <div class="tp-caption sfl tp-resizeme" data-x="left" data-hoffset="{{ slide_image_offset }}" data-y="center" data-voffset="0" data-speed="800" data-start="1300" data-easing="Power3.easeInOut" data-elementdelay="0.1" data-endelementdelay="0.1" data-endspeed="300" data-scrolloffset="0" style="z-index: 3;"><img src="{{ layer_image }}" alt="{{ slide_product.title | escape }}"></div>
                      <div class="tp-caption lfb tp-resizeme" data-x="left" data-hoffset="550" data-y="center" data-voffset="100" data-speed="800" data-start="1300" data-easing="Power3.easeInOut" data-elementdelay="0.1" data-endelementdelay="0.1" data-endspeed="300" data-scrolloffset="0" style="z-index: 8;"><a href="{{ slide_product.url }}" class="btn-round big">{{ slide_button_label }}</a></div>
                    </li>
                  {% endfor %}
                {% else %}
                  <li class="home-hero-merchandising-slide" data-transition="random" data-slotamount="7" data-masterspeed="300" data-saveperformance="off">
                    <img src="{{ 'trans-bg.png' | asset_url }}" alt="slider" data-bgposition="center center" data-bgfit="cover" data-bgrepeat="no-repeat">
                    <div class="hero-slide-overlay" style="background-color: {{ slide_overlay_color }}; opacity: {{ slide_overlay_opacity }};"></div>
                    <div class="tp-caption sfl tp-resizeme" data-x="left" data-hoffset="550" data-y="center" data-voffset="-80" data-speed="800" data-start="800" data-easing="Power3.easeInOut" data-splitin="chars" data-splitout="none" data-elementdelay="0.03" data-endelementdelay="0.4" data-endspeed="300" style="z-index: 5; font-size:26px; font-weight:500; color:#888888;  max-width: auto; max-height: auto; white-space: nowrap;">Select a collection</div>
                    <div class="tp-caption sfr tp-resizeme" data-x="left" data-hoffset="550" data-y="center" data-voffset="-40" data-speed="800" data-start="1000" data-easing="Power3.easeInOut" data-splitin="chars" data-splitout="none" data-elementdelay="0.03" data-endelementdelay="0.1" data-endspeed="300" style="z-index: 6; font-size:36px; color:#22c961; font-weight:800; white-space: nowrap;">Home Hero Merchandising</div>
                    <div class="tp-caption sfl tp-resizeme" data-x="left" data-hoffset="{{ slide_image_offset }}" data-y="center" data-voffset="0" data-speed="800" data-start="1300" data-easing="Power3.easeInOut" data-elementdelay="0.1" data-endelementdelay="0.1" data-endspeed="300" data-scrolloffset="0" style="z-index: 3;"><img src="{{ 'slide-item-7-2.png' | asset_url }}" alt="Home Hero Merchandising"></div>
                    <div class="tp-caption lfb tp-resizeme" data-x="left" data-hoffset="550" data-y="center" data-voffset="100" data-speed="800" data-start="1300" data-easing="Power3.easeInOut" data-elementdelay="0.1" data-endelementdelay="0.1" data-endspeed="300" data-scrolloffset="0" style="z-index: 8;"><a href="{{ routes.collections_url }}" class="btn-round big">{{ slide_button_label }}</a></div>
                  </li>
                {% endif %}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% style %}
  #shopify-section-{{ section.id }} .home-hero-merchandising-slide {
    position: relative;
  }

  #shopify-section-{{ section.id }} .home-hero-merchandising-slide .hero-slide-overlay {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 2;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .tp-bgimg {
    background-repeat: no-repeat !important;
    background-size: cover !important;
    background-position: center center !important;
  }
{% endstyle %}

{% schema %}
{
  "name": "Home Hero Merchandising",
  "settings": [
    {
      "type": "link_list",
      "id": "categories_menu",
      "label": "Categories menu"
    },
    {
      "type": "collection",
      "id": "merch_collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Number of slides",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "slider_autoplay",
      "label": "Auto-rotate slides",
      "default": true
    },
    {
      "type": "range",
      "id": "slider_delay_seconds",
      "label": "Slide rotation delay",
      "min": 3,
      "max": 15,
      "step": 1,
      "unit": "s",
      "default": 9
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_bullets",
      "label": "Show bullets",
      "default": true
    },
    {
      "type": "range",
      "id": "slider_height",
      "label": "Slider height",
      "min": 380,
      "max": 700,
      "step": 10,
      "unit": "px",
      "default": 500
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 35
    },
    {
      "type": "range",
      "id": "image_offset",
      "label": "Foreground horizontal offset",
      "min": 0,
      "max": 300,
      "step": 10,
      "default": 50
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    }
  ],
  "presets": [
    {
      "name": "Home Hero Merchandising"
    }
  ]
}
{% endschema %}
