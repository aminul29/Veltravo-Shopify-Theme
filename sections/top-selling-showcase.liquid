{%- liquid
  assign showcase_collection = section.settings.collection
  assign featured_product = section.settings.featured_product
  if featured_product == blank and showcase_collection != blank and showcase_collection.products_count > 0
    assign featured_product = showcase_collection.products.first
  endif
-%}

<!-- Top Selling Week -->
<section class="padding-bottom-60 padding-top-60">
  <div class="container">
    <div class="heading">
      <h2>{{ section.settings.heading }}</h2>
      <hr>
    </div>
    <div class="row">
      <div class="col-md-6">
        <div class="item-col-2">
          {% if showcase_collection != blank and showcase_collection.products_count > 0 %}
            {%- liquid
              assign rendered_count = 0
            -%}
            {% for product in showcase_collection.products %}
              {% if featured_product != blank and product.id == featured_product.id %}
                {% continue %}
              {% endif %}
              {% render 'product-card', product: product %}
              {%- liquid
                assign rendered_count = rendered_count | plus: 1
              -%}
              {% if rendered_count >= section.settings.products_limit %}
                {% break %}
              {% endif %}
            {% endfor %}
            {% if rendered_count == 0 %}
              {% render 'product-card', fallback_image: 'item-img-1-6.jpg', fallback_tag: 'Tablets', fallback_title: 'Mp3 Sumergible Deportivo Slim Con 8GB', fallback_price: '$350.00', fallback_compare_price: '$200.00' %}
              {% render 'product-card', fallback_image: 'item-img-1-7.jpg', fallback_tag: 'Appliances', fallback_title: 'Reloj Inteligente Smart Watch M26 Touch Bluetooh', fallback_price: '$350.00' %}
              {% render 'product-card', fallback_image: 'item-img-1-8.jpg', fallback_tag: 'Accessories', fallback_title: 'Teclado Inalambrico Bluetooth Con Air Mouse', fallback_price: '$350.00' %}
              {% render 'product-card', fallback_image: 'item-img-1-10.jpg', fallback_tag: 'Appliances', fallback_title: 'Reloj Inteligente Smart Watch M26 Touch Bluetooh', fallback_price: '$350.00' %}
            {% endif %}
          {% else %}
            {% render 'product-card', fallback_image: 'item-img-1-6.jpg', fallback_tag: 'Tablets', fallback_title: 'Mp3 Sumergible Deportivo Slim Con 8GB', fallback_price: '$350.00', fallback_compare_price: '$200.00' %}
            {% render 'product-card', fallback_image: 'item-img-1-7.jpg', fallback_tag: 'Appliances', fallback_title: 'Reloj Inteligente Smart Watch M26 Touch Bluetooh', fallback_price: '$350.00' %}
            {% render 'product-card', fallback_image: 'item-img-1-8.jpg', fallback_tag: 'Accessories', fallback_title: 'Teclado Inalambrico Bluetooth Con Air Mouse', fallback_price: '$350.00' %}
            {% render 'product-card', fallback_image: 'item-img-1-10.jpg', fallback_tag: 'Appliances', fallback_title: 'Reloj Inteligente Smart Watch M26 Touch Bluetooh', fallback_price: '$350.00' %}
          {% endif %}
        </div>
      </div>

      <div class="col-md-6">
        <div class="product">
          <article>
            <div class="thumb-slider">
              <ul class="slides">
                {% if featured_product != blank %}
                  {%- liquid
                    assign media_count = 0
                  -%}
                  {% for media in featured_product.media %}
                    {% if media.media_type == 'image' %}
                      <li data-thumb="{{ media | image_url: width: 480 }}"> {{ media | image_url: width: 900 | image_tag: alt: featured_product.title | escape }} </li>
                      {%- liquid
                        assign media_count = media_count | plus: 1
                      -%}
                    {% endif %}
                    {% if media_count >= section.settings.featured_media_limit %}
                      {% break %}
                    {% endif %}
                  {% endfor %}
                  {% if media_count == 0 %}
                    {% if featured_product.featured_image %}
                      <li data-thumb="{{ featured_product.featured_image | image_url: width: 480 }}"> {{ featured_product.featured_image | image_url: width: 900 | image_tag: alt: featured_product.title | escape }} </li>
                    {% endif %}
                  {% endif %}
                {% else %}
                  <li data-thumb="{{ 'item-img-1-6.jpg' | asset_url }}"> <img src="{{ 'item-img-1-6.jpg' | asset_url }}" alt=""> </li>
                  <li data-thumb="{{ 'item-img-1-7.jpg' | asset_url }}"> <img src="{{ 'item-img-1-7.jpg' | asset_url }}" alt=""> </li>
                  <li data-thumb="{{ 'item-img-1-15.jpg' | asset_url }}"> <img src="{{ 'item-img-1-15.jpg' | asset_url }}" alt=""> </li>
                  <li data-thumb="{{ 'item-img-1-2.jpg' | asset_url }}"> <img src="{{ 'item-img-1-2.jpg' | asset_url }}" alt=""> </li>
                {% endif %}
              </ul>
            </div>

            {% if featured_product != blank %}
              <span class="tag">{{ featured_product.type | default: featured_product.vendor | escape }}</span>
              <a href="{{ featured_product.url }}" class="tittle">{{ featured_product.title }}</a>
              <p class="rev"><i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i> <i class="fa fa-star-o"></i> <span class="margin-left-10">5 Review(s)</span></p>
              <div class="price">
                {{ featured_product.price | money }}
                {% if featured_product.compare_at_price > featured_product.price %}
                  <span>{{ featured_product.compare_at_price | money }}</span>
                {% endif %}
              </div>
              <a href="{{ featured_product.url }}" class="cart-btn"><i class="icon-basket-loaded"></i></a>
            {% else %}
              <span class="tag">Appliances</span> <a href="#." class="tittle">Reloj Inteligente Smart Watch M26 Touch Bluetooh </a>
              <p class="rev"><i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i> <i class="fa fa-star-o"></i> <span class="margin-left-10">5 Review(s)</span></p>
              <div class="price">$350.00</div>
              <a href="#." class="cart-btn"><i class="icon-basket-loaded"></i></a>
            {% endif %}
          </article>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Top Selling Showcase",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Top Selling of the Week"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Products collection"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured product"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Products to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "featured_media_limit",
      "label": "Featured media thumbnails",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Top Selling Showcase"
    }
  ]
}
{% endschema %}
