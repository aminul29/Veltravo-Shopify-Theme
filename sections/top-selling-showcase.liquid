{%- liquid
  assign featured_product = section.settings.featured_product
  assign displayed = 0
-%}

<section class="top-selling section-shell">
  <div class="page-width">
    <div class="section-heading">
      <h2>
        {% if section.settings.heading != blank %}
          {{ section.settings.heading | escape }}
        {% else %}
          {{ 'sections.top_selling_showcase.default_heading' | t }}
        {% endif %}
      </h2>
      {% if section.settings.subheading != blank %}
        <p>{{ section.settings.subheading | escape }}</p>
      {% endif %}
    </div>
    <div class="top-selling__grid">
      <div class="top-selling__featured">
        {% if featured_product == blank and section.settings.collection != blank and section.settings.collection.products_count > 0 %}
          {% assign featured_product = section.settings.collection.products.first %}
        {% endif %}
        {% if featured_product != blank %}
          {% render 'product-card', product: featured_product, show_vendor: true %}
        {% else %}
          <div class="top-selling__empty card-surface">{{ 'general.empty.collection' | t }}</div>
        {% endif %}
      </div>
      <div class="top-selling__products">
        {% if section.settings.collection != blank and section.settings.collection.products_count > 0 %}
          <div class="top-selling__products-grid">
            {% for product in section.settings.collection.products %}
              {% if featured_product != blank and product.id == featured_product.id %}
                {% continue %}
              {% endif %}
              {% if displayed >= section.settings.product_limit %}
                {% break %}
              {% endif %}
              {% render 'product-card', product: product, show_vendor: section.settings.show_vendor %}
              {% assign displayed = displayed | plus: 1 %}
            {% endfor %}
          </div>
        {% else %}
          <div class="top-selling__empty card-surface">{{ 'general.empty.collection' | t }}</div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .top-selling__grid {
    display: grid;
    grid-template-columns: minmax(260px, 0.9fr) minmax(0, 1.5fr);
    gap: 1rem;
  }

  .top-selling__products-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .top-selling__empty {
    padding: 1.5rem;
  }

  @media screen and (max-width: 989px) {
    .top-selling__grid {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    .top-selling__products-grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.top_selling_showcase.name",
  "class": "section-top-selling-showcase",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:labels.subheading"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:labels.collection"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "t:labels.product"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "t:labels.product_limit",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:labels.show_vendor",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "t:sections.top_selling_showcase.name"
    }
  ]
}
{% endschema %}
