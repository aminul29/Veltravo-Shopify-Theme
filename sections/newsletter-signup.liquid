<!-- Newslatter -->
<section class="newslatter">
  <div class="container">
    <div class="row">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'content' %}
            <div class="col-md-6" {{ block.shopify_attributes }}>
              <h3>{{ block.settings.heading }} <span>{{ block.settings.subheading }}</span></h3>
            </div>
          {% elsif block.type == 'form' %}
            <div class="col-md-6" {{ block.shopify_attributes }}>
              {% form 'customer', class: 'newsletter-form' %}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <input type="email" name="contact[email]" placeholder="{{ block.settings.placeholder }}" required>
                <button type="submit">{{ block.settings.button_label }}</button>
              {% endform %}
            </div>
          {% endif %}
        {% endfor %}
      {% else %}
        <div class="col-md-6">
          <h3>{{ section.settings.heading }} <span>{{ section.settings.subheading }}</span></h3>
        </div>
        <div class="col-md-6">
          {% form 'customer', class: 'newsletter-form' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <input type="email" name="contact[email]" placeholder="{{ section.settings.placeholder }}" required>
            <button type="submit">{{ section.settings.button_label }}</button>
          {% endform %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter Signup",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Subscribe our Newsletter"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "Get <strong>25% Off</strong> first purchase!"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Your email address here..."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe!"
    }
  ],
  "blocks": [
    {
      "type": "content",
      "name": "Content",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Subscribe our Newsletter"
        },
        {
          "type": "inline_richtext",
          "id": "subheading",
          "label": "Subheading",
          "default": "Get <strong>25% Off</strong> first purchase!"
        }
      ]
    },
    {
      "type": "form",
      "name": "Form",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "placeholder",
          "label": "Input placeholder",
          "default": "Your email address here..."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Subscribe!"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Newsletter Signup",
      "blocks": [
        {
          "type": "content"
        },
        {
          "type": "form"
        }
      ]
    }
  ]
}
{% endschema %}
