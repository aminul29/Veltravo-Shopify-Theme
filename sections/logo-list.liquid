<section class="logo-list section-shell">
  <div class="page-width">
    <div class="section-heading">
      <h2>
        {% if section.settings.heading != blank %}
          {{ section.settings.heading | escape }}
        {% else %}
          {{ 'sections.logo_list.default_heading' | t }}
        {% endif %}
      </h2>
    </div>
    <div class="logo-list__grid card-surface">
      {% for block in section.blocks %}
        <div class="logo-list__item" {{ block.shopify_attributes }}>
          {% if block.settings.link != blank %}<a href="{{ block.settings.link }}">{% endif %}
          {% if block.settings.logo_image != blank %}
            {{ block.settings.logo_image | image_url: width: 240 | image_tag: loading: 'lazy', widths: '120, 180, 240', alt: block.settings.title | escape }}
          {% else %}
            <span class="pill">{{ block.settings.title | default: shop.name | escape }}</span>
          {% endif %}
          {% if block.settings.link != blank %}</a>{% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .logo-list__grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1rem;
    padding: 1rem;
  }

  .logo-list__item {
    display: grid;
    place-items: center;
    min-height: 100px;
    padding: 1rem;
    border-radius: 1rem;
    background: color-mix(in srgb, var(--color-text) 4%, transparent);
  }

  .logo-list__item img {
    max-height: 42px;
    width: auto;
  }

  @media screen and (max-width: 989px) {
    .logo-list__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .logo-list__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.logo_list.name",
  "class": "section-logo-list",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "t:sections.logo_list.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo_image",
          "label": "t:labels.logo_image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:labels.link"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "t:sections.logo_list.name",
      "blocks": [
        {
          "type": "logo"
        },
        {
          "type": "logo"
        },
        {
          "type": "logo"
        },
        {
          "type": "logo"
        },
        {
          "type": "logo"
        }
      ]
    }
  ]
}
{% endschema %}
