{% doc %}
  Renders a single store benefit item.

  @param {object} [block] - Section block object
  @param {string} [icon_class] - Icon class fallback
  @param {string} [title] - Title fallback
  @param {string} [text] - Body text fallback
{% enddoc %}

{%- liquid
  assign benefit_icon = icon_class | default: 'flaticon-delivery-truck-1'
  assign benefit_title = title | default: 'Free Shipping'
  assign benefit_text = text | default: 'On order over $99'

  if block != blank
    assign benefit_icon = block.settings.icon_class | default: benefit_icon
    assign benefit_title = block.settings.title | default: benefit_title
    assign benefit_text = block.settings.text | default: benefit_text
  endif
-%}

<li {% if block != blank %}{{ block.shopify_attributes }}{% endif %}>
  <div class="media-left"> <i class="{{ benefit_icon }}"></i> </div>
  <div class="media-body">
    <h5>{{ benefit_title }}</h5>
    <span>{{ benefit_text }}</span>
  </div>
</li>
