{% case media.media_type %}
   {% when 'image' %}
      <img src="{{ media | image_url: width: 1200 }}" alt="{{ media.preview_image.alt | escape }}" class="w-full h-full object-cover" height="{{ media.preview_image.height }}" width="{{ media.preview_image.width }}">
   {% when 'external_video' %}
      {{ media | external_video_tag: class: 'w-full h-80 object-cover' }}
   {% when 'video' %}
      {{ media | video_tag: controls: true, class: 'w-full h-80 object-cover' }}
   {% when 'model' %}      <product-model data-media-id="{{ media.id }}">
         <div>
            <button id="productModelOpenButton_{{ media.id }}" x-on:click="productModalOpen = true" class="w-full h-full bg-gray-100 border border-gray-200 relative">
               <span class="border bg-gray-100 absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2">
                  {% render 'icon-model-viewer' %}
               </span>
               <img class="w-full h-full object-cover" src="{{ media | image_url: width: 1200 }}" alt="{{ media.preview_image.alt }}" height="{{ media.preview_image.height }}" width="{{ media.preview_image.width }}">
            </button>
         </div>
         <template>
            {{ media | model_viewer_tag: reveal: 'interaction' }}
         </template>
      </product-model>
   {% else %}
   {{ media | media_tag }}
      
{% endcase %}
